---
import BaseLayout from '@/layouts/BaseLayout.astro'
import PageHero from '@/components/sections/PageHero.astro'
import { t } from '@/lib/i18n'
const lang = (Astro.currentLocale ?? 'ru') as 'ru' | 'en' | 'de'
---
<BaseLayout title="Privacy Policy — Krüger Motor Oil">
  <PageHero
    title={t(lang, 'legal.privacyTitle')}
    breadcrumbs={[{ label: t(lang, 'common.breadcrumbHome'), href: '/' }, { label: 'Privacy Policy' }]}
  />
  <section class="bg-bg py-12 md:py-16">
    <div class="container-page max-w-3xl text-text-muted leading-relaxed space-y-4">
      <p class="text-sm text-text-muted bg-bg-soft border border-border-soft rounded-md px-4 py-3">{t(lang, 'legal.draftNotice')}</p>
      <p>Krüger Motor Oil GmbH (далее «мы», «нас») с серьёзностью относится к защите персональных данных. Настоящая политика описывает, какие данные собираются на сайте kruger-oil.de и как они используются.</p>
      <p>Полный текст Datenschutzerklärung по требованиям GDPR/DSGVO готовится юридическим отделом и будет опубликован до запуска в продакшн.</p>
    </div>
  </section>
</BaseLayout>
