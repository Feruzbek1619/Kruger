---
import BaseLayout from '@/layouts/BaseLayout.astro'
import PageHero from '@/components/sections/PageHero.astro'
import Card from '@/components/ui/Card.astro'
import Icon from '@/components/ui/Icon.astro'
import ru from '@/i18n/ru.json'
import { t } from '@/lib/i18n'
const lang = (Astro.currentLocale ?? 'ru') as 'ru' | 'en' | 'de'
const values = ru.about.vision.values
// Семантика: Качество, Технологии, Партнёрство, Ответственность
const valueIcons = ['award', 'spark', 'handshake', 'leaf'] as const
---
<BaseLayout title="Видение и миссия — Krüger Motor Oil">
  <PageHero
    eyebrow={t(lang, 'about.vision.eyebrow')}
    title={t(lang, 'about.vision.title')}
    lead={t(lang, 'about.vision.lead')}
    breadcrumbs={[{ label: t(lang, 'common.breadcrumbHome'), href: '/' }, { label: t(lang, 'nav.about'), href: '/about/glance/' }, { label: t(lang, 'nav.aboutVision') }]}
  />

  <!-- Vision + Mission — асимметричная пара: Vision залитая, Mission elevated -->
  <section class="bg-bg py-20 md:py-24">
    <div class="container-page grid gap-6 md:gap-8 md:grid-cols-2">
      <!-- VISION — filled dark, premium accent block -->
      <article class="kr-reveal relative overflow-hidden rounded-2xl bg-bg-dark text-text-inverse p-8 md:p-10 lg:p-12 min-h-[22rem] flex flex-col">
        <!-- Yellow diagonal stripe (brand reference) -->
        <span
          class="absolute -right-20 -top-20 w-56 h-[28rem] rotate-[18deg] bg-brand-yellow/[0.07] pointer-events-none"
          aria-hidden="true"
        />
        <span
          class="absolute -right-12 -top-12 w-1 h-[28rem] rotate-[18deg] bg-brand-yellow/40 pointer-events-none"
          aria-hidden="true"
        />

        <div class="relative">
          <div class="inline-flex items-center gap-3 mb-5">
            <span class="inline-block h-0.5 w-8 bg-brand-yellow" aria-hidden="true" />
            <p class="text-[10px] md:text-xs font-bold tracking-[0.22em] text-brand-yellow uppercase">Vision</p>
          </div>

          <span class="inline-flex h-14 w-14 items-center justify-center rounded-xl bg-brand-yellow text-black mb-6">
            <Icon name="eye" size={28} strokeWidth={2} />
          </span>

          <h2 class="font-display text-3xl md:text-4xl font-extrabold leading-tight mb-4">{t(lang, 'about.vision.vision.title')}</h2>
          <p class="text-text-inverse/80 leading-relaxed text-base md:text-lg">{t(lang, 'about.vision.vision.text')}</p>
        </div>
      </article>

      <!-- MISSION — elevated, brand red accent -->
      <article class="kr-reveal relative overflow-hidden rounded-2xl bg-bg border border-border-soft shadow-md p-8 md:p-10 lg:p-12 min-h-[22rem] flex flex-col">
        <!-- Yellow corner clip (brand accent) -->
        <span
          class="absolute top-0 right-0 w-24 h-24 bg-brand-yellow/15 pointer-events-none"
          style="clip-path: polygon(100% 0, 0 0, 100% 100%);"
          aria-hidden="true"
        />

        <div class="relative">
          <div class="inline-flex items-center gap-3 mb-5">
            <span class="inline-block h-0.5 w-8 bg-primary" aria-hidden="true" />
            <p class="text-[10px] md:text-xs font-bold tracking-[0.22em] text-primary uppercase">Mission</p>
          </div>

          <span class="inline-flex h-14 w-14 items-center justify-center rounded-xl bg-primary text-text-inverse mb-6">
            <Icon name="target" size={28} strokeWidth={2} />
          </span>

          <h2 class="font-display text-3xl md:text-4xl font-extrabold leading-tight mb-4 text-text">{t(lang, 'about.vision.mission.title')}</h2>
          <p class="text-text-muted leading-relaxed text-base md:text-lg">{t(lang, 'about.vision.mission.text')}</p>
        </div>
      </article>
    </div>
  </section>

  <!-- Values — 4 карточки с outline-watermark номерами + иконками -->
  <section class="bg-bg-soft py-20 md:py-24">
    <div class="container-page">
      <div class="text-center max-w-2xl mx-auto mb-12 md:mb-14">
        <div class="inline-flex items-center gap-3 mb-4">
          <span class="inline-block h-0.5 w-8 bg-primary" aria-hidden="true" />
          <p class="text-[10px] md:text-xs font-bold tracking-[0.22em] text-primary uppercase">Core Values</p>
          <span class="inline-block h-0.5 w-8 bg-primary" aria-hidden="true" />
        </div>
        <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-extrabold tracking-tight leading-[1.1]">{t(lang, 'about.vision.valuesTitle')}</h2>
      </div>

      <ul class="grid gap-5 md:gap-6 grid-cols-1 sm:grid-cols-2 lg:grid-cols-4">
        {values.map((v, i) => (
          <li class="kr-reveal">
            <Card variant="default" padding="lg" class="group relative h-full overflow-hidden hover:border-primary/30 hover:shadow-lg hover:-translate-y-1 transition-all duration-200">
              <!-- Outline number watermark -->
              <span
                class="absolute -top-2 -right-1 font-display font-extrabold text-[5.5rem] leading-none select-none pointer-events-none"
                style="-webkit-text-stroke: 2px var(--color-primary); color: transparent; opacity: 0.15;"
                aria-hidden="true"
              >{String(i + 1).padStart(2, '0')}</span>

              <!-- Top accent stripe (appears on hover) -->
              <span
                class="absolute top-0 left-0 right-0 h-1 bg-primary scale-x-0 origin-left group-hover:scale-x-100 transition-transform duration-300"
                aria-hidden="true"
              />

              <span class="relative inline-flex h-12 w-12 items-center justify-center rounded-xl bg-primary text-text-inverse mb-6 transition-transform group-hover:scale-110 group-hover:rotate-[-4deg]">
                <Icon name={valueIcons[i] ?? 'spark'} size={24} />
              </span>
              <h3 class="relative font-display font-bold text-lg md:text-xl leading-snug mb-3">{v.title}</h3>
              <p class="relative text-sm md:text-[0.9375rem] text-text-muted leading-relaxed">{v.text}</p>
            </Card>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-bg py-16 md:py-20 border-t border-border-soft">
    <div class="container-page text-center">
      <p class="text-text-muted mb-5 max-w-xl mx-auto text-base md:text-lg">Узнайте о наших обязательствах перед клиентами, партнёрами и окружающей средой.</p>
      <a
        href="/about/commitments/"
        class="group inline-flex items-center gap-3 h-12 pl-7 pr-2 rounded-pill bg-primary text-text-inverse font-semibold hover:bg-primary-hover transition-colors"
      >
        <span>{t(lang, 'about.glance.ctaCommitments')}</span>
        <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-brand-yellow text-black transition-transform group-hover:translate-x-1">
          <Icon name="arrowRight" size={16} strokeWidth={2.5} />
        </span>
      </a>
    </div>
  </section>
</BaseLayout>
