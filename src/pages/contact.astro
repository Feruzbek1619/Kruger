---
import BaseLayout from '@/layouts/BaseLayout.astro'
import PageHero from '@/components/sections/PageHero.astro'
import Card from '@/components/ui/Card.astro'
import Icon from '@/components/ui/Icon.astro'
import ContactFormFull from '@/components/sections/ContactFormFull.vue'
import ru from '@/i18n/ru.json'
import { t } from '@/lib/i18n'

const lang = (Astro.currentLocale ?? 'ru') as 'ru' | 'en' | 'de'

// Только региональные офисы. HQ (Stuttgart) — отдельной премиум-карточкой слева.
const offices = [
  { code: 'UZ', region: 'Узбекистан / Центральная Азия', name: 'UIC Group', city: 'Ташкент, Узбекистан', phone: '+998 71 200 70 07', email: 'info@uic.group' },
]

const formLabels = {
  name: t(lang, 'questionForm.nameLabel'),
  namePh: t(lang, 'questionForm.namePh'),
  phone: t(lang, 'questionForm.phoneLabel'),
  phonePh: t(lang, 'questionForm.phonePh'),
  email: t(lang, 'questionForm.emailLabel'),
  emailPh: t(lang, 'questionForm.emailPh'),
  message: t(lang, 'questionForm.messageLabel'),
  messagePh: t(lang, 'questionForm.messagePh'),
  consent: t(lang, 'questionForm.consent'),
  submit: t(lang, 'questionForm.submit'),
  sending: t(lang, 'questionForm.sending'),
  successToast: t(lang, 'questionForm.successToast'),
  errorToast: t(lang, 'questionForm.errorToast'),
}
const formErrors = {
  name: t(lang, 'questionForm.errors.name'),
  emailRequired: t(lang, 'questionForm.errors.emailRequired'),
  emailInvalid: t(lang, 'questionForm.errors.emailInvalid'),
  message: t(lang, 'questionForm.errors.message'),
  consent: t(lang, 'questionForm.errors.consent'),
}
---
<BaseLayout
  title="Контакты — Krüger Motor Oil"
  description="Главный офис в Stuttgart, региональные представительства в Центральной Азии и СНГ. Свяжитесь с нами через форму обратной связи."
  hideContactStrip
>
  <PageHero
    eyebrow="Get in touch"
    title={t(lang, 'contactPage.title')}
    lead={t(lang, 'contactPage.lead')}
    breadcrumbs={[{ label: t(lang, 'common.breadcrumbHome'), href: '/' }, { label: t(lang, 'nav.contact') }]}
  />

  <section class="bg-bg py-16 md:py-24">
    <div class="container-page grid gap-8 lg:grid-cols-12 lg:gap-10">
      <!-- HQ — премиум-карточка с картой, 7 колонок -->
      <div class="lg:col-span-7 kr-reveal">
        <div class="flex items-center gap-3 mb-4">
          <span class="inline-block h-0.5 w-8 bg-primary" aria-hidden="true" />
          <p class="text-[10px] md:text-xs font-bold tracking-[0.22em] text-primary uppercase">Headquarters</p>
        </div>
        <h2 class="font-display text-3xl md:text-4xl font-extrabold tracking-tight leading-tight mb-6">{t(lang, 'contactPage.hqTitle')}</h2>

        <Card variant="elevated" padding="none" class="overflow-hidden">
          <div class="p-7 md:p-8 lg:p-10">
            <div class="flex items-center gap-3 mb-4">
              <span class="inline-flex h-7 px-2.5 items-center rounded-md bg-primary text-text-inverse text-xs font-bold tracking-wider leading-none">DE</span>
              <span class="text-xs font-bold tracking-wider text-text-muted uppercase">Germany</span>
            </div>
            <p class="font-display text-xl md:text-2xl font-bold text-text">Krüger Motor Oil GmbH</p>
            <p class="text-text-muted text-sm md:text-[0.9375rem] mt-1.5">Leitzstraße 45, 70469 Stuttgart, Germany</p>

            <ul class="mt-6 space-y-3">
              <li class="flex items-center gap-3.5">
                <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-bg-soft text-primary shrink-0">
                  <Icon name="phone" size={18} />
                </span>
                <a href="tel:+4971112345678" class="font-medium hover:text-primary transition-colors">+49 711 12 34 56 78</a>
              </li>
              <li class="flex items-center gap-3.5">
                <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-bg-soft text-primary shrink-0">
                  <Icon name="mail" size={18} />
                </span>
                <a href="mailto:info@kruger-oil.de" class="font-medium hover:text-primary transition-colors">info@kruger-oil.de</a>
              </li>
              <li class="flex items-start gap-3.5">
                <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-bg-soft text-primary shrink-0">
                  <Icon name="clock" size={18} />
                </span>
                <span class="text-text-muted whitespace-pre-line leading-relaxed pt-2 text-sm md:text-[0.9375rem]">{t(lang, 'contactPage.hours')}</span>
              </li>
            </ul>
          </div>

          <iframe
            class="w-full aspect-[16/9] border-t border-border-soft"
            loading="lazy"
            src="https://www.openstreetmap.org/export/embed.html?bbox=9.1310%2C48.7700%2C9.2010%2C48.8050&layer=mapnik&marker=48.7900%2C9.1700"
            title="Карта офиса Krüger в Stuttgart"
          ></iframe>
        </Card>
      </div>

      <!-- Региональные + соцсети — 5 колонок -->
      <div class="lg:col-span-5 kr-reveal">
        <div class="flex items-center gap-3 mb-4">
          <span class="inline-block h-0.5 w-8 bg-primary" aria-hidden="true" />
          <p class="text-[10px] md:text-xs font-bold tracking-[0.22em] text-primary uppercase">Regional</p>
        </div>
        <h2 class="font-display text-3xl md:text-4xl font-extrabold tracking-tight leading-tight mb-6">{t(lang, 'contactPage.regionalTitle')}</h2>

        <ul class="grid gap-4 mb-8">
          {offices.map((o) => (
            <li>
              <Card variant="default" padding="lg" class="group hover:border-primary/30 hover:shadow-md hover:-translate-y-0.5 transition-all duration-200">
                <div class="flex items-center gap-3 mb-3">
                  <span class="inline-flex h-7 px-2.5 items-center rounded-md bg-bg-soft text-text-subtle text-xs font-bold tracking-wider leading-none border border-border-soft">{o.code}</span>
                  <p class="text-sm font-medium text-text-muted">{o.region}</p>
                </div>
                <p class="font-display text-lg md:text-xl font-bold">{o.name}</p>
                <p class="text-text-muted text-sm mt-1">{o.city}</p>
                <ul class="mt-4 space-y-2.5 text-sm">
                  <li class="flex items-center gap-2.5">
                    <Icon name="phone" size={16} class="text-primary shrink-0" />
                    <a href={`tel:${o.phone.replace(/\s/g, '')}`} class="hover:text-primary transition-colors">{o.phone}</a>
                  </li>
                  <li class="flex items-center gap-2.5">
                    <Icon name="mail" size={16} class="text-primary shrink-0" />
                    <a href={`mailto:${o.email}`} class="hover:text-primary transition-colors">{o.email}</a>
                  </li>
                </ul>
              </Card>
            </li>
          ))}
        </ul>

        <!-- Social media tile group -->
        <div class="p-6 rounded-xl bg-bg-soft border border-border-soft">
          <div class="flex items-center gap-3 mb-4">
            <span class="inline-block h-0.5 w-6 bg-primary" aria-hidden="true" />
            <p class="text-[10px] font-bold tracking-[0.22em] text-primary uppercase">Follow</p>
          </div>
          <h3 class="font-display text-base font-bold mb-4">{t(lang, 'contactPage.socialTitle')}</h3>
          <div class="flex items-center gap-2.5">
            {['facebook','instagram','youtube','linkedin'].map((s) => (
              <a
                href="#"
                aria-label={s}
                class="inline-flex h-11 w-11 items-center justify-center rounded-lg bg-bg text-text border border-border-soft hover:bg-primary hover:text-text-inverse hover:border-primary hover:-translate-y-0.5 transition-all duration-200"
              >
                <Icon name={s} size={18} />
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Form section -->
  <section class="bg-bg-soft py-20 md:py-24 relative overflow-hidden">
    <span
      class="absolute -right-32 -top-32 w-72 h-[42rem] rotate-[18deg] bg-brand-yellow/[0.04] pointer-events-none"
      aria-hidden="true"
    />
    <div class="relative container-page max-w-3xl">
      <div class="text-center mb-10 md:mb-12">
        <div class="inline-flex items-center gap-3 mb-4">
          <span class="inline-block h-0.5 w-8 bg-primary" aria-hidden="true" />
          <p class="text-[10px] md:text-xs font-bold tracking-[0.22em] text-primary uppercase">Write to us</p>
          <span class="inline-block h-0.5 w-8 bg-primary" aria-hidden="true" />
        </div>
        <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-extrabold tracking-tight leading-[1.1]">{t(lang, 'contactPage.writeTitle')}</h2>
      </div>

      <ContactFormFull
        client:visible
        topics={ru.contactPage.topics}
        topicLabel={`${t(lang, 'contactPage.fields.topic')} *`}
        topicPh={t(lang, 'contactPage.fields.topicPlaceholder')}
        companyLabel={t(lang, 'contactPage.fields.company')}
        companyPh={t(lang, 'contactPage.fields.companyPh')}
        labels={formLabels}
        errors={formErrors}
      />
    </div>
  </section>
</BaseLayout>
