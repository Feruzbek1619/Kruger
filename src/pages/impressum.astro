---
import BaseLayout from '@/layouts/BaseLayout.astro'
import PageHero from '@/components/sections/PageHero.astro'
import { t } from '@/lib/i18n'
const lang = (Astro.currentLocale ?? 'ru') as 'ru' | 'en' | 'de'
---
<BaseLayout title="Impressum — Krüger Motor Oil GmbH">
  <PageHero
    title={t(lang, 'legal.impressumTitle')}
    breadcrumbs={[{ label: t(lang, 'common.breadcrumbHome'), href: '/' }, { label: 'Impressum' }]}
  />
  <section class="bg-bg py-12 md:py-16">
    <div class="container-page max-w-3xl prose-news">
      <p class="text-sm text-text-muted bg-bg-soft border border-border-soft rounded-md px-4 py-3">{t(lang, 'legal.draftNotice')}</p>

      <h2>Krüger Motor Oil GmbH</h2>
      <p>Leitzstraße 45<br>70469 Stuttgart<br>Deutschland</p>

      <h2>Vertreten durch / Представитель</h2>
      <p>[Имя директора]</p>

      <h2>Kontakt / Контакт</h2>
      <p>Telefon: +49 711 12 34 56 78<br>E-Mail: info@kruger-oil.de</p>

      <h2>Registereintrag / Регистрация</h2>
      <p>Eingetragen im Handelsregister<br>Registergericht: Amtsgericht Stuttgart<br>Registernummer: HRB …</p>

      <h2>Umsatzsteuer-ID / НДС</h2>
      <p>USt-IdNr. nach §27 a UStG: DE…</p>

      <h2>Verantwortlich für den Inhalt / Ответственный за контент</h2>
      <p>[Имя]</p>

      <h2>Streitschlichtung / Разрешение споров</h2>
      <p>Wir sind nicht bereit oder verpflichtet, an Streitbeilegungsverfahren vor einer Verbraucherschlichtungsstelle teilzunehmen.</p>

      <h2>Haftung für Inhalte</h2>
      <p>Als Diensteanbieter sind wir gemäß § 7 Abs.1 TMG für eigene Inhalte auf diesen Seiten nach den allgemeinen Gesetzen verantwortlich.</p>
    </div>
  </section>
</BaseLayout>

<style is:global>
  .prose-news h2 { font-family: var(--font-display); font-weight: 700; font-size: var(--text-xl); margin: 1.75rem 0 0.5rem; color: var(--color-text); }
  .prose-news p  { margin-block: 0.5rem; line-height: 1.6; color: var(--color-text); }
</style>
