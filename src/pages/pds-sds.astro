---
import BaseLayout from '@/layouts/BaseLayout.astro'
import PageHero from '@/components/sections/PageHero.astro'
import Icon from '@/components/ui/Icon.astro'
import popular from '@/mocks/popular.json'
import { t } from '@/lib/i18n'
const lang = (Astro.currentLocale ?? 'ru') as 'ru' | 'en' | 'de'
---
<BaseLayout title="PDS / SDS — технические документы Krüger">
  <PageHero
    title={t(lang, 'pdsSds.title')}
    lead={t(lang, 'pdsSds.lead')}
    breadcrumbs={[{ label: t(lang, 'common.breadcrumbHome'), href: '/' }, { label: 'PDS / SDS' }]}
  />
  <section class="bg-bg py-12 md:py-16">
    <div class="container-page">
      <div class="grid gap-3 md:grid-cols-[1fr_auto_auto] md:items-end mb-8">
        <label class="flex flex-col gap-1.5">
          <span class="text-sm font-medium text-text">{t(lang, 'pdsSds.searchPh')}</span>
          <input type="search" placeholder={t(lang, 'pdsSds.searchPh')} class="h-11 rounded-md bg-bg-soft border-2 border-transparent hover:border-border focus:border-primary focus:bg-bg px-4 text-base focus:outline-none" />
        </label>
        <label class="flex flex-col gap-1.5 md:w-56">
          <span class="text-sm font-medium text-text">Категория</span>
          <select class="h-11 rounded-md bg-bg-soft border-2 border-transparent hover:border-border focus:border-primary focus:bg-bg px-4 text-base focus:outline-none">
            <option>{t(lang, 'pdsSds.categoryAll')}</option>
            <option>Engine Oils</option>
            <option>Hydraulic</option>
            <option>ATF</option>
            <option>EV Fluids</option>
          </select>
        </label>
        <label class="flex flex-col gap-1.5 md:w-40">
          <span class="text-sm font-medium text-text">Язык</span>
          <select class="h-11 rounded-md bg-bg-soft border-2 border-transparent hover:border-border focus:border-primary focus:bg-bg px-4 text-base focus:outline-none">
            <option>{t(lang, 'pdsSds.languageRu')}</option>
            <option>{t(lang, 'pdsSds.languageEn')}</option>
            <option>{t(lang, 'pdsSds.languageDe')}</option>
          </select>
        </label>
      </div>

      <div class="overflow-x-auto rounded-lg border border-border-soft">
        <table class="w-full text-sm">
          <thead class="bg-bg-soft text-text-subtle uppercase text-xs">
            <tr>
              <th class="text-left font-semibold px-4 py-3">Продукт</th>
              <th class="text-left font-semibold px-4 py-3">Артикул</th>
              <th class="text-left font-semibold px-4 py-3">PDS</th>
              <th class="text-left font-semibold px-4 py-3">SDS</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border-soft bg-bg">
            {(popular as any[]).map((p) => (
              <tr class="hover:bg-bg-soft transition-colors">
                <td class="px-4 py-3 font-medium text-text">{p.name}</td>
                <td class="px-4 py-3 text-text-muted">{p.sku}</td>
                <td class="px-4 py-3">
                  <div class="flex gap-2">
                    {['RU','EN','DE'].map((l) => (
                      <a href="#" class="inline-flex items-center gap-1 px-2.5 py-1 rounded bg-bg-soft text-xs hover:bg-primary hover:text-text-inverse transition-colors">
                        <Icon name="download" class="h-3 w-3" />
                        {l}
                      </a>
                    ))}
                  </div>
                </td>
                <td class="px-4 py-3">
                  <div class="flex gap-2">
                    {['RU','EN','DE'].map((l) => (
                      <a href="#" class="inline-flex items-center gap-1 px-2.5 py-1 rounded bg-bg-soft text-xs hover:bg-primary hover:text-text-inverse transition-colors">
                        <Icon name="download" class="h-3 w-3" />
                        {l}
                      </a>
                    ))}
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="mt-6 text-sm text-text-muted">{t(lang, 'pdsSds.noticeText')}</p>
      <p class="mt-2 text-xs text-text-subtle italic">{t(lang, 'pdsSds.soonNotice')}</p>
    </div>
  </section>
</BaseLayout>
