---
import BaseLayout from '@/layouts/BaseLayout.astro'
import PageHero from '@/components/sections/PageHero.astro'
import Icon from '@/components/ui/Icon.astro'
import allProducts from '@/mocks/all-products.json'
import categories from '@/mocks/categories.json'
import { t } from '@/lib/i18n'
import type { Product } from '@/types'

const lang = (Astro.currentLocale ?? 'ru') as 'ru' | 'en' | 'de'
const products = allProducts as Product[]

// Used categories (only those that have products)
const usedCategoryIds = [...new Set(products.map((p) => p.category).filter(Boolean))] as string[]
const usedCategories = (categories as { id: string; title: string }[])
  .filter((c) => usedCategoryIds.includes(c.id))
  .map((c) => ({ id: c.id, title: c.title }))
---
<BaseLayout
  title="PDS / SDS — технические документы Krüger"
  description="Product Data Sheet и Safety Data Sheet на 40+ продуктов Krüger. Поиск по названию, артикулу, фильтр по категории и языку."
>
  <PageHero
    title={t(lang, 'pdsSds.title')}
    lead={t(lang, 'pdsSds.lead')}
    breadcrumbs={[{ label: t(lang, 'common.breadcrumbHome'), href: '/' }, { label: 'PDS / SDS' }]}
  />
  <section class="bg-bg py-12 md:py-16">
    <div class="container-page">
      <div class="grid gap-3 md:grid-cols-[1fr_auto_auto] md:items-end mb-8">
        <label class="flex flex-col gap-1.5">
          <span class="text-sm font-medium text-text">{t(lang, 'pdsSds.searchPh')}</span>
          <input
            id="pds-search"
            type="search"
            placeholder={t(lang, 'pdsSds.searchPh')}
            class="h-11 rounded-md bg-bg-soft border border-input hover:border-muted-foreground/50 focus:border-primary/60 focus:bg-bg focus:ring-4 focus:ring-primary/10 px-4 text-base focus:outline-none"
          />
        </label>
        <label class="flex flex-col gap-1.5 md:w-56">
          <span class="text-sm font-medium text-text">Категория</span>
          <select id="pds-category" class="h-11 rounded-md bg-bg-soft border border-input hover:border-muted-foreground/50 focus:border-primary/60 focus:bg-bg focus:ring-4 focus:ring-primary/10 px-4 text-base focus:outline-none">
            <option value="">{t(lang, 'pdsSds.categoryAll')}</option>
            {usedCategories.map((c) => (
              <option value={c.id}>{c.title}</option>
            ))}
          </select>
        </label>
        <label class="flex flex-col gap-1.5 md:w-40">
          <span class="text-sm font-medium text-text">Язык</span>
          <select id="pds-language" class="h-11 rounded-md bg-bg-soft border border-input hover:border-muted-foreground/50 focus:border-primary/60 focus:bg-bg focus:ring-4 focus:ring-primary/10 px-4 text-base focus:outline-none">
            <option value="">Все языки</option>
            <option value="RU">{t(lang, 'pdsSds.languageRu')}</option>
            <option value="EN">{t(lang, 'pdsSds.languageEn')}</option>
            <option value="DE">{t(lang, 'pdsSds.languageDe')}</option>
          </select>
        </label>
      </div>

      <p class="text-sm text-text-muted mb-4">
        <span id="pds-count">{products.length}</span> документов
      </p>

      <div class="overflow-x-auto rounded-lg border border-border-soft">
        <table class="w-full text-sm">
          <thead class="bg-bg-soft text-text-subtle uppercase text-xs">
            <tr>
              <th class="text-left font-semibold px-4 py-3">Продукт</th>
              <th class="text-left font-semibold px-4 py-3">Артикул</th>
              <th class="text-left font-semibold px-4 py-3">PDS</th>
              <th class="text-left font-semibold px-4 py-3">SDS</th>
            </tr>
          </thead>
          <tbody id="pds-tbody" class="divide-y divide-border-soft bg-bg">
            {products.map((p) => (
              <tr class="pds-row hover:bg-bg-soft transition-colors" data-name={p.name.toLowerCase()} data-sku={p.sku.toLowerCase()} data-category={p.category ?? ''}>
                <td class="px-4 py-3 font-medium text-text">{p.name}</td>
                <td class="px-4 py-3 text-text-muted font-mono text-xs">{p.sku}</td>
                <td class="px-4 py-3">
                  <div class="flex gap-2">
                    {['RU','EN','DE'].map((l) => (
                      <a
                        href="#"
                        data-pds-lang={l}
                        class="pds-link inline-flex items-center gap-1 px-2.5 py-1 rounded bg-bg-soft text-xs hover:bg-primary hover:text-text-inverse transition-colors"
                      >
                        <Icon name="download" class="h-3 w-3" />
                        {l}
                      </a>
                    ))}
                  </div>
                </td>
                <td class="px-4 py-3">
                  <div class="flex gap-2">
                    {['RU','EN','DE'].map((l) => (
                      <a
                        href="#"
                        data-pds-lang={l}
                        class="pds-link inline-flex items-center gap-1 px-2.5 py-1 rounded bg-bg-soft text-xs hover:bg-primary hover:text-text-inverse transition-colors"
                      >
                        <Icon name="download" class="h-3 w-3" />
                        {l}
                      </a>
                    ))}
                  </div>
                </td>
              </tr>
            ))}
            <tr id="pds-empty" hidden>
              <td colspan="4" class="px-4 py-10 text-center text-text-muted">Ничего не найдено — попробуйте другой запрос</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="mt-6 text-sm text-text-muted">{t(lang, 'pdsSds.noticeText')}</p>
      <p class="mt-2 text-xs text-text-subtle italic">{t(lang, 'pdsSds.soonNotice')}</p>
    </div>
  </section>

  <script>
    // Простая клиентская фильтрация — search по name/sku, category, language toggle.
    const init = () => {
      const search = document.getElementById('pds-search') as HTMLInputElement | null
      const catSel = document.getElementById('pds-category') as HTMLSelectElement | null
      const langSel = document.getElementById('pds-language') as HTMLSelectElement | null
      const rows = Array.from(document.querySelectorAll<HTMLTableRowElement>('.pds-row'))
      const empty = document.getElementById('pds-empty')
      const counter = document.getElementById('pds-count')

      function apply() {
        const q = (search?.value ?? '').trim().toLowerCase()
        const cat = catSel?.value ?? ''
        const lang = langSel?.value ?? ''

        let visible = 0
        rows.forEach((row) => {
          const name = row.dataset.name ?? ''
          const sku = row.dataset.sku ?? ''
          const rowCat = row.dataset.category ?? ''
          const matchQ = !q || name.includes(q) || sku.includes(q)
          const matchCat = !cat || rowCat === cat
          const show = matchQ && matchCat
          row.hidden = !show
          if (show) visible++
        })

        // Language filter — dim non-matching pds-link buttons
        rows.forEach((row) => {
          const links = row.querySelectorAll<HTMLAnchorElement>('.pds-link')
          links.forEach((a) => {
            const matchLang = !lang || a.dataset.pdsLang === lang
            a.style.opacity = matchLang ? '1' : '0.3'
            a.style.pointerEvents = matchLang ? '' : 'none'
          })
        })

        if (counter) counter.textContent = String(visible)
        if (empty) empty.hidden = visible > 0
      }

      search?.addEventListener('input', apply)
      catSel?.addEventListener('change', apply)
      langSel?.addEventListener('change', apply)
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init, { once: true })
    } else {
      init()
    }
  </script>
</BaseLayout>
