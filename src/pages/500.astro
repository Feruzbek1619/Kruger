---
import BaseLayout from '@/layouts/BaseLayout.astro'
import { t } from '@/lib/i18n'
const lang = (Astro.currentLocale ?? 'ru') as 'ru' | 'en' | 'de'
---
<BaseLayout title="500 — Ошибка сервера | Krüger" hideContactStrip>
  <section class="bg-bg-soft py-20 md:py-28 min-h-[60vh] flex items-center">
    <div class="container-page max-w-xl text-center">
      <p class="font-display text-7xl md:text-8xl font-extrabold text-primary mb-4">500</p>
      <h1 class="font-display text-2xl md:text-3xl font-bold tracking-tight mb-4">{t(lang, 'errors.500Title')}</h1>
      <p class="text-text-muted mb-8">{t(lang, 'errors.500Lead')}</p>
      <a href="/" class="inline-flex h-12 px-7 items-center rounded-pill bg-primary text-text-inverse font-medium hover:bg-primary-hover transition-colors">{t(lang, 'errors.500Btn')}</a>
    </div>
  </section>
</BaseLayout>
