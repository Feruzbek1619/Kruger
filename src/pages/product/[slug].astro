---
import BaseLayout from '@/layouts/BaseLayout.astro'
import PageHero from '@/components/sections/PageHero.astro'
import ProductGallery from '@/components/products/ProductGallery.vue'
import RequestPriceForm from '@/components/products/RequestPriceForm.vue'
import ProductSpecsTable from '@/components/products/ProductSpecsTable.astro'
import RelatedProducts from '@/components/products/RelatedProducts.astro'
import Tabs from '@/components/ui/Tabs.vue'
import Icon from '@/components/ui/Icon.astro'
import allProducts from '@/mocks/all-products.json'
import productDetails from '@/mocks/product-details.json'
import categories from '@/mocks/categories.json'
import { t } from '@/lib/i18n'
import type { Product } from '@/types'

export async function getStaticPaths() {
  const list = allProducts as Product[]
  return list.map((p) => ({ params: { slug: p.slug }, props: { product: p } }))
}

const lang = (Astro.currentLocale ?? 'ru') as 'ru' | 'en' | 'de'
const { product } = Astro.props as { product: Product }

const details = (productDetails as Record<string, any>)[product.slug] ?? (productDetails as any)._default
const fallback = (productDetails as any)._default

const d = {
  description:        details.description       || fallback.description,
  engineTypes:        details.engineTypes?.length      ? details.engineTypes      : fallback.engineTypes,
  notRecommendedFor:  details.notRecommendedFor?.length ? details.notRecommendedFor : fallback.notRecommendedFor,
  intervals:          details.intervals?.length        ? details.intervals        : fallback.intervals,
  compatible:         details.compatible       || fallback.compatible,
  oemApprovals:       details.oemApprovals?.length     ? details.oemApprovals     : fallback.oemApprovals,
  recommendedFor:     details.recommendedFor?.length   ? details.recommendedFor   : fallback.recommendedFor,
  physicalProps:      details.physicalProps?.length    ? details.physicalProps    : fallback.physicalProps,
  benefits:           details.benefits?.length         ? details.benefits         : fallback.benefits,
}

const category = (categories as any[]).find((c) => c.id === product.category)
const categoryTitle = category?.title ?? 'Продукция'

const apiSpecs  = (product as any).apiSpec ?? []
const aceaSpecs = (product as any).aceaSpec ?? []
const compliesWith = [...apiSpecs, ...aceaSpecs]

// Иконки преимуществ — циклятся по списку d.benefits
const benefitIcons = ['shield', 'spark', 'drop', 'thermo', 'cog', 'leaf'] as const

const tabs = [
  { id: 'description',    label: t(lang, 'products.detail.tabDescription') },
  { id: 'application',    label: t(lang, 'products.detail.tabApplication') },
  { id: 'specifications', label: t(lang, 'products.detail.tabSpecifications') },
  { id: 'properties',     label: t(lang, 'products.detail.tabProperties') },
  { id: 'benefits',       label: t(lang, 'products.detail.tabBenefits') },
]

const formLabels = {
  name:       t(lang, 'questionForm.nameLabel'),
  namePh:     t(lang, 'questionForm.namePh'),
  email:      t(lang, 'questionForm.emailLabel'),
  emailPh:    t(lang, 'questionForm.emailPh'),
  phone:      t(lang, 'questionForm.phoneLabel'),
  phonePh:    t(lang, 'questionForm.phonePh'),
  qty:        t(lang, 'products.detail.qtyLabel'),
  qtyPh:      t(lang, 'products.detail.qtyPh'),
  consent:    t(lang, 'questionForm.consent'),
  submit:     t(lang, 'questionForm.submit'),
  sending:    t(lang, 'questionForm.sending'),
  successToast: t(lang, 'questionForm.successToast'),
  errorToast:   t(lang, 'questionForm.errorToast'),
}
const formErrors = {
  name:           t(lang, 'questionForm.errors.name'),
  emailRequired:  t(lang, 'questionForm.errors.emailRequired'),
  emailInvalid:   t(lang, 'questionForm.errors.emailInvalid'),
  consent:        t(lang, 'questionForm.errors.consent'),
}

// Schema.org/Product JSON-LD for rich results in Google
const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  sku: product.sku,
  description: product.shortDescription,
  image: product.image ? `https://kruger-oil.de${product.image}` : undefined,
  category: categoryTitle,
  brand: { '@type': 'Brand', name: 'Krüger Motor Oil' },
  manufacturer: { '@type': 'Organization', name: 'Krüger Motor Oil GmbH' },
  url: `https://kruger-oil.de/product/${product.slug}/`,
  offers: {
    '@type': 'Offer',
    availability: 'https://schema.org/InStock',
    priceCurrency: 'EUR',
    price: '0',          // цены через "Запросить цену" — POA
    priceValidUntil: new Date(Date.now() + 365 * 24 * 60 * 60 * 1000).toISOString().slice(0, 10),
    seller: { '@type': 'Organization', name: 'Krüger Motor Oil GmbH' },
  },
}
---
<BaseLayout
  title={`${product.name} — ${product.shortDescription.substring(0, 60)}... | Krüger`}
  description={product.shortDescription}
  jsonLd={productSchema}
>
  <PageHero
    breadcrumbs={[
      { label: t(lang, 'common.breadcrumbHome'), href: '/' },
      { label: 'Продукты',                       href: '/products/' },
      { label: categoryTitle,                    href: category ? category.href : '/products/' },
      { label: product.name },
    ]}
  />

  <!-- Hero block: gallery + info, premium 2-col layout -->
  <section class="bg-bg pt-4 pb-16 md:pb-24" id="product-hero">
    <div class="container-page grid gap-10 lg:gap-12 lg:grid-cols-2 items-start">
      <ProductGallery
        client:visible
        images={product.image
          ? [product.image, product.image === '/products/kruger-1.webp' ? '/products/kruger-2.webp' : '/products/kruger-1.webp']
          : []}
        alt={product.name}
        category={product.category}
        viscosity={(product as any).viscosity ?? ''}
        sku={product.sku}
        transition:name={`product-img-${product.slug}`}
      />

      <div class="lg:pt-2">
        <!-- Category eyebrow -->
        <div class="inline-flex items-center gap-3 mb-4">
          <span class="inline-block h-0.5 w-8 bg-primary" aria-hidden="true" />
          <p class="text-[10px] md:text-xs font-bold tracking-[0.22em] text-primary uppercase">{categoryTitle}</p>
        </div>

        <!-- Product name -->
        <h1
          class="font-display text-3xl md:text-4xl lg:text-5xl font-extrabold tracking-tight leading-[1.1] mb-3"
          transition:name={`product-title-${product.slug}`}
        >
          {product.name}
        </h1>

        <!-- SKU + viscosity badge row -->
        <div class="flex flex-wrap items-center gap-3 mb-6">
          <span class="text-sm text-text-muted">
            <span class="font-medium">{t(lang, 'products.detail.sku')}:</span> <span class="font-mono">{product.sku}</span>
          </span>
          {(product as any).viscosity && (
            <span class="inline-flex h-7 px-2.5 items-center rounded-md bg-primary text-text-inverse text-xs font-bold tracking-wider">
              {(product as any).viscosity}
            </span>
          )}
        </div>

        <!-- Lead description -->
        <p class="text-base md:text-lg text-text leading-relaxed mb-7">
          {product.shortDescription}
        </p>

        {product.volumes && product.volumes.length > 0 && (
          <div class="mb-8 pt-6 border-t border-border-soft">
            <p class="text-[10px] md:text-xs uppercase tracking-[0.18em] text-text-muted font-bold mb-3">
              {t(lang, 'products.detail.availableVolumes')}
            </p>
            <ul class="flex flex-wrap gap-2">
              {product.volumes.map((v, i) => (
                <li>
                  <button
                    type="button"
                    data-volume={v}
                    class:list={[
                      'kr-volume-chip inline-flex h-10 px-4 items-center rounded-pill text-sm font-semibold font-mono transition-colors',
                      i === 0
                        ? 'bg-primary text-text-inverse border border-primary'
                        : 'bg-bg text-text border border-border-soft hover:border-primary hover:text-primary',
                    ]}
                  >{v}</button>
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- CTAs row -->
        <div class="flex flex-col sm:flex-row flex-wrap gap-3 pt-6 border-t border-border-soft">
          <RequestPriceForm
            client:idle
            productName={product.name}
            productSku={product.sku}
            triggerLabel={t(lang, 'products.detail.requestPrice')}
            title={t(lang, 'products.detail.requestPriceTitle')}
            labels={formLabels}
            errors={formErrors}
          />
          <a
            href={`/pds-sds/?product=${product.slug}#pds`}
            class="inline-flex items-center justify-center gap-2 h-10 px-5 rounded-pill border border-border-soft bg-bg text-text font-semibold text-sm hover:border-primary hover:text-primary transition-colors"
          >
            <Icon name="download" class="h-4 w-4" />
            {t(lang, 'products.detail.downloadPDS')}
          </a>
          <a
            href={`/pds-sds/?product=${product.slug}#sds`}
            class="inline-flex items-center justify-center gap-2 h-10 px-5 rounded-pill border border-border-soft bg-bg text-text font-semibold text-sm hover:border-primary hover:text-primary transition-colors"
          >
            <Icon name="download" class="h-4 w-4" />
            {t(lang, 'products.detail.downloadSDS')}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Sticky compact summary bar (shows on scroll past hero) -->
  <div
    id="product-sticky"
    class="sticky top-0 z-[60] bg-bg/95 backdrop-blur-md border-b border-border-soft -translate-y-full opacity-0 transition-all duration-300 ease-out"
  >
    <div class="container-page py-3 flex items-center gap-4">
      <span class="hidden sm:inline-flex h-10 w-10 items-center justify-center rounded-md bg-bg-soft shrink-0 overflow-hidden">
        {product.image ? (
          <img src={product.image} alt="" class="max-h-full max-w-full object-contain" loading="lazy" />
        ) : (
          <span class="font-mono text-[10px] font-bold text-text">{(product as any).viscosity ?? 'K'}</span>
        )}
      </span>
      <div class="flex-1 min-w-0">
        <p class="font-display font-bold text-sm md:text-base text-text truncate">{product.name}</p>
        <p class="text-xs text-text-muted font-mono">{product.sku}</p>
      </div>
      <a
        href="#product-hero"
        class="hidden md:inline-flex items-center gap-2 h-10 px-4 rounded-pill border border-border-soft text-sm font-semibold text-text hover:border-primary hover:text-primary transition-colors"
      >
        {t(lang, 'products.detail.requestPrice')}
      </a>
    </div>
  </div>

  <!-- Tabs section -->
  <section class="bg-bg-soft py-16 md:py-24">
    <div class="container-page">
      <Tabs client:visible tabs={tabs}>

        <!-- Description -->
        <div slot="description" class="max-w-3xl mx-auto py-2">
          <p class="text-lg md:text-xl text-text leading-relaxed whitespace-pre-line mb-8">
            {d.description}
          </p>
          {d.benefits?.length > 0 && (
            <div>
              <p class="text-[10px] md:text-xs uppercase tracking-[0.18em] text-text-muted font-bold mb-4">
                Ключевые преимущества
              </p>
              <ul class="grid gap-3 sm:grid-cols-2">
                {d.benefits.slice(0, 6).map((b: string) => (
                  <li class="flex items-start gap-3 text-sm md:text-base text-text leading-snug">
                    <Icon name="check" class="h-5 w-5 text-primary shrink-0 mt-0.5" />
                    <span>{b}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>

        <!-- Application -->
        <div slot="application" class="grid gap-8 md:grid-cols-2 max-w-4xl mx-auto py-2">
          {d.engineTypes.length > 0 && (
            <div class="bg-bg rounded-xl border border-border-soft p-6 md:p-7">
              <h3 class="font-display font-bold text-lg mb-4">{t(lang, 'products.detail.engineTypes')}</h3>
              <ul class="space-y-3">
                {d.engineTypes.map((e: string) => (
                  <li class="flex items-start gap-3 text-sm md:text-base text-text leading-snug">
                    <Icon name="check" class="h-5 w-5 text-success shrink-0 mt-0.5" />
                    <span>{e}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
          {d.notRecommendedFor.length > 0 && (
            <div class="bg-bg rounded-xl border border-border-soft p-6 md:p-7">
              <h3 class="font-display font-bold text-lg mb-4">{t(lang, 'products.detail.notRecommended')}</h3>
              <ul class="space-y-3">
                {d.notRecommendedFor.map((n: string) => (
                  <li class="flex items-start gap-3 text-sm md:text-base text-text leading-snug">
                    <Icon name="close" class="h-5 w-5 text-error shrink-0 mt-0.5" />
                    <span>{n}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
          {d.intervals.length > 0 && (
            <div class="md:col-span-2 bg-bg rounded-xl border border-border-soft p-6 md:p-7">
              <h3 class="font-display font-bold text-lg mb-4">{t(lang, 'products.detail.intervals')}</h3>
              <ul class="divide-y divide-border-soft">
                {d.intervals.map((iv: { label: string; value: string }) => (
                  <li class="flex items-baseline justify-between gap-4 py-3 text-sm md:text-base">
                    <span class="text-text-muted">{iv.label}</span>
                    <span class="font-bold font-mono text-text">{iv.value}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
          {d.compatible && (
            <div class="md:col-span-2 bg-bg rounded-xl border border-border-soft p-6 md:p-7">
              <h3 class="font-display font-bold text-lg mb-3">{t(lang, 'products.detail.compatible')}</h3>
              <p class="text-sm md:text-base text-text-muted leading-relaxed">{d.compatible}</p>
            </div>
          )}
        </div>

        <!-- Specifications -->
        <div slot="specifications" class="grid gap-6 max-w-4xl mx-auto py-2">
          {compliesWith.length > 0 && (
            <div class="bg-bg rounded-xl border border-border-soft p-6 md:p-7">
              <h3 class="font-display font-bold text-lg mb-4">{t(lang, 'products.detail.compliesWith')}</h3>
              <ul class="flex flex-wrap gap-2">
                {compliesWith.map((s: string) => (
                  <li>
                    <span class="inline-flex h-8 px-3 items-center rounded-pill bg-bg-soft text-text border border-border-soft text-xs font-mono font-semibold">{s}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
          {d.oemApprovals.length > 0 && (
            <div class="bg-bg rounded-xl border border-border-soft p-6 md:p-7">
              <h3 class="font-display font-bold text-lg mb-4">{t(lang, 'products.detail.oemApprovals')}</h3>
              <ul class="flex flex-wrap gap-2">
                {d.oemApprovals.map((o: string) => (
                  <li>
                    <span class="inline-flex h-8 px-3 items-center rounded-pill bg-primary text-text-inverse text-xs font-mono font-bold">{o}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
          {d.recommendedFor.length > 0 && (
            <div class="bg-bg rounded-xl border border-border-soft p-6 md:p-7">
              <h3 class="font-display font-bold text-lg mb-4">{t(lang, 'products.detail.recommendedFor')}</h3>
              <ul class="grid gap-2.5 sm:grid-cols-2 text-sm">
                {d.recommendedFor.map((r: string) => (
                  <li class="flex items-start gap-2.5">
                    <Icon name="check" class="h-4 w-4 text-primary shrink-0 mt-1" />
                    <span class="text-text">{r}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>

        <!-- Properties -->
        <div slot="properties" class="max-w-4xl mx-auto py-2">
          <ProductSpecsTable
            rows={d.physicalProps}
            labels={{
              param:  t(lang, 'products.detail.param'),
              value:  t(lang, 'products.detail.value'),
              method: t(lang, 'products.detail.method'),
            }}
          />
        </div>

        <!-- Benefits — 2x3 grid cards with icons -->
        <div slot="benefits" class="max-w-5xl mx-auto py-2">
          <ul class="grid gap-4 md:gap-5 sm:grid-cols-2 lg:grid-cols-3">
            {d.benefits.map((b: string, i: number) => (
              <li class="group flex flex-col gap-4 p-6 md:p-7 bg-bg rounded-xl border border-border-soft hover:border-primary/40 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200">
                <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary transition-colors group-hover:bg-primary group-hover:text-text-inverse shrink-0">
                  <Icon name={benefitIcons[i % benefitIcons.length]} class="h-6 w-6" />
                </span>
                <p class="text-sm md:text-base text-text leading-snug font-medium">{b}</p>
              </li>
            ))}
          </ul>
        </div>

      </Tabs>
    </div>
  </section>

  <RelatedProducts
    currentSlug={product.slug}
    currentCategory={product.category}
    title={t(lang, 'products.detail.relatedTitle')}
    ctaLabel={t(lang, 'products.moreDetails')}
  />

  <script>
    // Sticky compact summary bar — shows after scrolling past hero (~600px).
    const init = () => {
      const sticky = document.getElementById('product-sticky')
      const hero = document.getElementById('product-hero')
      if (!sticky || !hero) return
      const heroBottom = hero.offsetTop + hero.offsetHeight - 80
      let shown = false
      const update = () => {
        const should = window.scrollY > heroBottom
        if (should === shown) return
        shown = should
        sticky.classList.toggle('-translate-y-full', !should)
        sticky.classList.toggle('opacity-0', !should)
      }
      update()
      window.addEventListener('scroll', update, { passive: true })
      window.addEventListener('resize', update)
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init, { once: true })
    } else {
      init()
    }

    // Volume chips — toggle active state on click (UI-only; not wired to data yet).
    document.addEventListener('click', (e) => {
      const target = e.target as HTMLElement
      const chip = target?.closest('.kr-volume-chip') as HTMLButtonElement | null
      if (!chip) return
      const siblings = chip.parentElement?.parentElement?.querySelectorAll('.kr-volume-chip')
      siblings?.forEach((s) => {
        s.classList.remove('bg-primary', 'text-text-inverse', 'border-primary')
        s.classList.add('bg-bg', 'text-text', 'border-border-soft', 'hover:border-primary', 'hover:text-primary')
      })
      chip.classList.remove('bg-bg', 'text-text', 'border-border-soft', 'hover:border-primary', 'hover:text-primary')
      chip.classList.add('bg-primary', 'text-text-inverse', 'border-primary')
    })
  </script>
</BaseLayout>
