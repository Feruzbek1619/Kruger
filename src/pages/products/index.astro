---
/**
 * /products/ — каталог продукции с фильтрами (Phase 4 DoD).
 *
 * Структура:
 *   1) PageHero (заголовок + breadcrumbs)
 *   2) SegmentStrip — горизонтальная strip из 6 сегментов как chips
 *   3) ProductCatalogShell — orchestrator с sidebar-фильтрами, sort, view,
 *      grid/list, pagination и URL-state синхронизацией
 *
 * URL-параметры: ?application=car&viscosity=5W-30&page=2&sort=az&view=list
 * Все читаются ProductCatalogShell на mount.
 */
import BaseLayout from '@/layouts/BaseLayout.astro'
import PageHero from '@/components/sections/PageHero.astro'
import SegmentStrip from '@/components/products/SegmentStrip.astro'
import ProductCatalogShell from '@/components/products/ProductCatalogShell.vue'
import { t } from '@/lib/i18n'
import allProducts from '@/mocks/all-products.json'
import segments from '@/mocks/segments.json'
import categories from '@/mocks/categories.json'

const lang = (Astro.currentLocale ?? 'ru') as 'ru' | 'en' | 'de'

const applicationOptions = (segments as { id: string; title: string }[]).map((s) => ({
  id: s.id,
  label: s.title,
}))

// Словарь категорий: { engine: "Моторные масла", hydraulic: "Гидравлические масла", ... }
const categoryLabels = (categories as { id: string; title: string }[]).reduce<Record<string, string>>(
  (acc, c) => { acc[c.id] = c.title; return acc }, {}
)

const labels = {
  filters:             t(lang, 'products.filters'),
  filterByApplication: t(lang, 'products.filterByApplication'),
  filterByType:        t(lang, 'products.filterByType'),
  filterByViscosity:   t(lang, 'products.filterByViscosity'),
  filterBySpec:        t(lang, 'products.filterBySpec'),
  filterByVolume:      t(lang, 'products.filterByVolume'),
  resetFilters:        t(lang, 'products.resetFilters'),
  sortLabel:           t(lang, 'products.sortLabel'),
  sortPopular:         t(lang, 'products.sortPopular'),
  sortNew:             t(lang, 'products.sortNew'),
  sortAZ:              t(lang, 'products.sortAZ'),
  sortZA:              t(lang, 'products.sortZA'),
  viewGrid:            t(lang, 'products.viewGrid'),
  viewList:            t(lang, 'products.viewList'),
  found:               t(lang, 'products.found'),
  productsWord:        t(lang, 'products.products'),
  showFilters:         t(lang, 'products.showFilters'),
  showProducts:        t(lang, 'products.showProducts'),
  paginationPrev:      t(lang, 'products.paginationPrev'),
  paginationNext:      t(lang, 'products.paginationNext'),
  paginationShowing:   t(lang, 'products.paginationShowing'),
  emptyTitle:          t(lang, 'products.emptyTitle'),
  emptyText:           t(lang, 'products.emptyText'),
  moreDetails:         t(lang, 'products.moreDetails'),
}
---
<BaseLayout
  title="Каталог продукции Krüger — моторные, гидравлические, ATF, EV Fluids"
  description="150+ премиальных смазочных материалов Krüger с фильтрами по применению, вязкости, API/ACEA-спецификации и объёму упаковки. Скачать PDS/SDS."
>
  <PageHero
    title={t(lang, 'products.listingHeroTitle')}
    lead={t(lang, 'products.listingHeroLead')}
    breadcrumbs={[
      { label: t(lang, 'common.breadcrumbHome'), href: '/' },
      { label: 'Каталог' },
    ]}
  />

  <SegmentStrip />

  <ProductCatalogShell
    client:idle
    products={allProducts as any}
    applicationOptions={applicationOptions}
    categoryLabels={categoryLabels}
    labels={labels}
  />
</BaseLayout>
