---
import BaseLayout from '@/layouts/BaseLayout.astro'
import PageHero from '@/components/sections/PageHero.astro'
import ProductCard from '@/components/cards/ProductCard.vue'
import ProductRange from '@/components/sections/ProductRange.astro'
import popular from '@/mocks/popular.json'
import { t } from '@/lib/i18n'
const lang = (Astro.currentLocale ?? 'ru') as 'ru' | 'en' | 'de'
---
<BaseLayout title="Каталог продукции Krüger — моторные, гидравлические, трансмиссионные масла">
  <PageHero
    title={t(lang, 'products.listingTitle')}
    lead={t(lang, 'products.listingLead')}
    breadcrumbs={[{ label: t(lang, 'common.breadcrumbHome'), href: '/' }, { label: 'Продукты' }]}
  />
  <section class="bg-bg py-12 md:py-16">
    <div class="container-page">
      <p class="text-sm text-text-muted bg-bg-soft border border-border-soft rounded-md px-4 py-3 mb-10">{t(lang, 'products.soonNotice')}</p>
      <ul class="grid gap-5 md:gap-6 grid-cols-1 sm:grid-cols-2 lg:grid-cols-4">
        {(popular as any[]).map((p) => (
          <li><ProductCard product={p} ctaLabel={t(lang, 'popular.more')} client:visible /></li>
        ))}
      </ul>
    </div>
  </section>
  <ProductRange />
</BaseLayout>
