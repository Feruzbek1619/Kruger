---
import '@/styles/global.css'
import { ClientRouter } from 'astro:transitions'
import TopBar from '@/components/layouts/TopBar.astro'
import Header from '@/components/layouts/Header.astro'
import Footer from '@/components/layouts/Footer.astro'
import ContactStrip from '@/components/sections/ContactStrip.astro'
import FloatingButtons from '@/components/ui/FloatingButtons.vue'
import Toast from '@/components/ui/Toast.vue'

interface Props {
  title?: string
  description?: string
  hideContactStrip?: boolean
  /** URL картинки, которая является LCP-кандидатом — будет preload в <head>. */
  preloadImage?: string
  /** Canonical URL for SEO + og:url (auto: Astro.url.pathname). */
  canonical?: string
  /** Open Graph image URL (1200×630 recommended). Defaults to /og.png */
  ogImage?: string
  /** Дополнительный JSON-LD schema (Article, Product, etc.) — на специфичных страницах */
  jsonLd?: Record<string, unknown>
}

const {
  title = 'Krüger Motor Oil — премиальные моторные масла, разработанные в Германии',
  description = 'Krüger — производитель премиальных моторных и индустриальных масел из Штутгарта. 150+ продуктов, OEM-одобрения ведущих автопроизводителей, поставки в 50+ стран.',
  hideContactStrip = false,
  preloadImage,
  canonical,
  ogImage = '/og.png',
  jsonLd,
} = Astro.props

const lang = (Astro.currentLocale ?? 'ru') as 'ru' | 'en' | 'de'

const siteUrl = 'https://kruger-oil.de'
const canonicalUrl = canonical ?? `${siteUrl}${Astro.url.pathname}`
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`

// Organization schema — рендерится на всех страницах
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Krüger Motor Oil GmbH',
  alternateName: 'Krüger',
  url: siteUrl,
  logo: `${siteUrl}/logo.svg`,
  description,
  foundingDate: '2017',
  foundingLocation: { '@type': 'Place', name: 'Stuttgart, Germany' },
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Leitzstraße 45',
    postalCode: '70469',
    addressLocality: 'Stuttgart',
    addressCountry: 'DE',
  },
  contactPoint: [{
    '@type': 'ContactPoint',
    telephone: '+49-711-12-34-56-78',
    email: 'info@kruger-oil.de',
    contactType: 'customer support',
    availableLanguage: ['Russian', 'English', 'German'],
  }],
  sameAs: [],
}
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="canonical" href={canonicalUrl} />
    {preloadImage && <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Krüger Motor Oil" />
    <meta property="og:locale" content={lang === 'ru' ? 'ru_RU' : lang === 'de' ? 'de_DE' : 'en_US'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:url" content={canonicalUrl} />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- JSON-LD Organization schema (every page) -->
    <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

    <ClientRouter />
  </head>
  <body class="bg-bg text-text">
    <a href="#main" class="skip-link">К основному контенту</a>
    <TopBar />
    <Header />
    <main id="main">
      <slot />
    </main>
    {!hideContactStrip && <ContactStrip />}
    <Footer />
    <FloatingButtons client:idle />
    <Toast client:idle />

    <script>
      // Motion One reveal + count-up + Lenis smooth scroll.
      // Перезапуск после Astro View Transitions (astro:page-load).
      import { revealOnScroll, bindCountUps } from '@/lib/motion'
      import { initLenis } from '@/lib/lenis'
      const init = () => {
        revealOnScroll()
        bindCountUps()
        initLenis()
      }
      document.addEventListener('astro:page-load', init)
    </script>
  </body>
</html>
