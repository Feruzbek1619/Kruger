---
interface Props {
  variant?: 'color' | 'white' | 'dark'
  class?: string
}
const { variant = 'color', class: extra = 'h-10' } = Astro.props

const fill = variant === 'white' ? 'white' : variant === 'dark' ? 'var(--foreground)' : 'var(--primary)'
const txt  = variant === 'white' ? 'white' : 'var(--foreground)'
---
<svg viewBox="0 0 200 56" class={extra} role="img" aria-label="Krüger Motor Oil">
  <rect x="0" y="0" width="56" height="56" rx="6" fill={fill} />
  <path d="M14 12h6v14l11-14h7l-12 15 13 17h-8l-11-15v15h-6V12Z" fill="white" />
  <text
    x="64"
    y="26"
    font-family="Manrope Variable, system-ui, sans-serif"
    font-size="18"
    font-weight="800"
    letter-spacing="-0.02em"
    fill={txt}
  >KRÜGER</text>
  <text
    x="64"
    y="46"
    font-family="Inter Variable, system-ui, sans-serif"
    font-size="11"
    font-weight="500"
    letter-spacing="0.05em"
    fill={txt}
    opacity="0.7"
  >MOTOR OIL · MADE IN GERMANY</text>
</svg>
