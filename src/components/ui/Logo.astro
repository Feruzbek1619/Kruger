---
/**
 * Krüger Motor Oil — официальный логотип.
 * Жёлтая фигура (#F8CC0F = --color-brand-yellow), К-знак + текст «RÜGER».
 *
 * variant:
 *   - color (default): жёлтый фон + чёрный текст. Для светлых страниц.
 *   - white: жёлтый фон + белый текст. Для тёмных секций (footer).
 *   - mono: всё в currentColor (наследует цвет родителя). Для favicon-стилей.
 */
interface Props {
  variant?: 'color' | 'white' | 'mono'
  class?: string
}
const { variant = 'color', class: extra = 'h-10' } = Astro.props

// SVG fill atribute не читает CSS-переменные надёжно в браузерах,
// поэтому жёлтый используем литерально (это бренд-цвет, который не меняется).
const yellow = variant === 'mono' ? 'currentColor' : '#F8CC0F'
const ink    = variant === 'mono' ? 'currentColor' : variant === 'white' ? 'white' : 'black'
---
