---
/**
 * Krüger Card — обёртка над shadcn Card. Если нужна clickable-вариант,
 * пробрасываем href и оборачиваем в <a>. Padding/variant — наши пресеты.
 */
import { Card as ShadcnCard, CardContent } from '@/components/ui/shadcn/card'

interface Props {
  href?: string
  variant?: 'default' | 'elevated' | 'flat'
  padding?: 'none' | 'sm' | 'md' | 'lg'
  class?: string
}

const {
  href,
  variant = 'default',
  padding = 'md',
  class: extraClass = '',
} = Astro.props

const padMap = { none: 'p-0', sm: 'p-4', md: 'p-6', lg: 'p-8' } as const

const variantMap = {
  default: 'bg-card border border-border',
  elevated: 'bg-card border-0 shadow-md',
  flat: 'bg-muted border-0 shadow-none',
} as const

const cls = `block rounded-lg overflow-hidden gap-0 transition-all duration-200 ${variantMap[variant]} ${extraClass}`
const interactive = 'hover:-translate-y-0.5 hover:shadow-lg focus-visible:-translate-y-0.5 focus-visible:shadow-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 active:translate-y-0'
---

{href ? (
  <a href={href} class={`${cls} ${interactive}`}>
    <ShadcnCard class={`${padMap[padding]} border-0 shadow-none bg-transparent gap-0 py-0`}>
      <CardContent class="p-0">
        <slot />
      </CardContent>
    </ShadcnCard>
  </a>
) : (
  <ShadcnCard class={`${cls} ${padMap[padding]} gap-0 py-0`}>
    <CardContent class="p-0">
      <slot />
    </CardContent>
  </ShadcnCard>
)}
