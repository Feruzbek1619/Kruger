---
interface Props {
  size?: 'sm' | 'md' | 'lg'
  label?: string
}
const { size = 'md', label = 'Загружаем…' } = Astro.props
const sizeMap = { sm: 'h-4 w-4', md: 'h-6 w-6', lg: 'h-10 w-10' } as const
---
<span
  class:list={['inline-block rounded-pill border-2 border-current border-t-transparent animate-spin', sizeMap[size]]}
  role="status"
  aria-label={label}
></span>
