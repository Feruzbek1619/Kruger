---
import { t } from '@/lib/i18n'
import oem from '@/mocks/oem.json'
import type { OEMBrand } from '@/types'
const lang = (Astro.currentLocale ?? 'ru') as 'ru' | 'en' | 'de'
const brands = oem as OEMBrand[]
---
<section class="bg-bg py-16 md:py-24">
  <div class="container-page">
    <div class="text-center max-w-3xl mx-auto mb-10 md:mb-14">
      <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight">{t(lang, 'oem.title')}</h2>
      <p class="mt-3 text-text-muted">{t(lang, 'oem.subtitle')}</p>
    </div>

    <div class="grid gap-8 lg:grid-cols-[1fr_1.4fr] items-center">
      <div class="bg-primary text-text-inverse rounded-xl p-8 md:p-10">
        <p class="text-base md:text-lg leading-relaxed">{t(lang, 'oem.blockText')}</p>
        <p class="mt-4 text-base md:text-lg leading-relaxed opacity-90">{t(lang, 'oem.blockText2')}</p>
        <a href="/about/glance/" class="mt-6 inline-flex items-center h-11 px-6 rounded-pill bg-bg text-text font-medium hover:bg-bg-soft transition-colors">
          {t(lang, 'oem.cta')}
        </a>
      </div>

      <ul class="grid grid-cols-3 sm:grid-cols-4 gap-3 md:gap-4">
        {brands.map((b) => (
          <li>
            <div
              class="group h-20 md:h-24 flex items-center justify-center rounded-lg border border-border-soft bg-bg p-4 grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-200"
              title={b.name}
            >
              {b.logo ? (
                <img src={b.logo} alt={b.name} loading="lazy" class="max-h-full max-w-full object-contain" />
              ) : (
                <span class="font-display font-bold text-sm md:text-base text-text-subtle text-center">{b.name}</span>
              )}
            </div>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
