---
import { t } from '@/lib/i18n'
import Icon from '@/components/ui/Icon.astro'
import oem from '@/mocks/oem.json'
import type { OEMBrand } from '@/types'
const lang = (Astro.currentLocale ?? 'ru') as 'ru' | 'en' | 'de'
const brands = oem as OEMBrand[]
---
<section class="bg-bg-soft py-16 md:py-24">
  <div class="container-page">
    <div class="text-center max-w-3xl mx-auto mb-12 md:mb-16">
      <div class="flex items-center justify-center gap-3 mb-4">
        <span class="inline-block h-0.5 w-10 bg-primary" aria-hidden="true" />
        <p class="text-[10px] md:text-xs font-bold tracking-[0.2em] text-primary uppercase">ОДОБРЕНО OEM</p>
        <span class="inline-block h-0.5 w-10 bg-primary" aria-hidden="true" />
      </div>
      <h2 class="font-display text-3xl md:text-5xl font-extrabold tracking-tight leading-[1.1]">
        {t(lang, 'oem.title')}
      </h2>
      <p class="mt-4 text-base md:text-lg text-text-muted">{t(lang, 'oem.subtitle')}</p>
    </div>

    <div class="grid gap-8 lg:grid-cols-[1fr_1.6fr] items-stretch">
      <!-- Red panel with copy -->
      <div class="relative bg-primary text-text-inverse rounded-2xl p-8 md:p-10 overflow-hidden">
        <!-- Yellow stripe accent -->
        <span class="absolute top-0 left-0 right-0 h-1.5 bg-brand-yellow" aria-hidden="true" />
        <!-- Background K letter -->
        <span
          class="absolute -right-8 -bottom-12 font-display text-[18rem] font-extrabold leading-none text-text-inverse/[0.07] select-none pointer-events-none"
          aria-hidden="true"
        >K</span>

        <p class="relative text-base md:text-lg leading-relaxed">{t(lang, 'oem.blockText')}</p>
        <p class="relative mt-4 text-base md:text-lg leading-relaxed opacity-90">{t(lang, 'oem.blockText2')}</p>
        <a
          href="/about/glance/"
          class="relative mt-7 inline-flex items-center gap-3 h-11 pl-5 pr-2 rounded-pill bg-text-inverse text-text font-semibold text-sm hover:bg-text-inverse/90 transition-colors"
        >
          <span>{t(lang, 'oem.cta')}</span>
          <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-brand-yellow">
            <Icon name="arrowRight" class="h-4 w-4 text-text" />
          </span>
        </a>
      </div>

      <!-- OEM logos — 3 marquee rows alternating direction -->
      <div class="kr-oem-marquee space-y-4 md:space-y-5 overflow-hidden">
        {[0, 1, 2].map((rowIdx) => {
          const rowBrands = brands.slice(rowIdx * 4, rowIdx * 4 + 4)
          const direction = rowIdx % 2 === 0 ? 'left' : 'right'
          return (
            <div class:list={['kr-oem-row relative overflow-hidden', `kr-oem-row--${direction}`]}>
              <div class="kr-oem-track flex items-center gap-4 md:gap-5 w-max">
                {/* duplicated 4× for seamless loop */}
                {[...rowBrands, ...rowBrands, ...rowBrands, ...rowBrands].map((b) => (
                  <div
                    class="kr-oem-card group shrink-0 h-24 md:h-28 w-32 md:w-44 flex items-center justify-center rounded-xl bg-transparent p-3 md:p-4 transition-all duration-300 hover:bg-bg"
                    aria-label={b.name}
                  >
                    {b.logo ? (
                      <img src={b.logo} alt={b.name} loading="lazy" class="max-h-full max-w-full object-contain opacity-50 group-hover:opacity-100 transition-opacity duration-300" />
                    ) : (
                      <span class="font-display font-extrabold text-base md:text-lg text-text-subtle text-center group-hover:text-text transition-colors">{b.name}</span>
                    )}
                  </div>
                ))}
              </div>
            </div>
          )
        })}
      </div>
    </div>
  </div>
</section>

<style is:global>
  /* OEM marquee — 3 ряда чередуются по направлению.
     Используем translateX от 0 до -25% потому что трек состоит из 4 копий по 4 логотипа
     (т.е. 1 копия = 25% всей ширины — даёт seamless loop). */
  @keyframes kr-marquee-left {
    from { transform: translateX(0); }
    to   { transform: translateX(-25%); }
  }
  @keyframes kr-marquee-right {
    from { transform: translateX(-25%); }
    to   { transform: translateX(0); }
  }
  .kr-oem-row--left .kr-oem-track  { animation: kr-marquee-left 40s linear infinite; }
  .kr-oem-row--right .kr-oem-track { animation: kr-marquee-right 40s linear infinite; }
  /* Пауза на hover ряда — чтобы пользователь мог рассмотреть логотип */
  .kr-oem-row:hover .kr-oem-track { animation-play-state: paused; }

  /* Premium glow на hover карточки логотипа (вместо stark white card) */
  .kr-oem-card {
    will-change: transform, box-shadow;
  }
  .kr-oem-card:hover {
    box-shadow:
      0 0 0 1px rgb(229 30 37 / 0.08),
      0 8px 24px rgb(229 30 37 / 0.12),
      0 2px 8px rgb(0 0 0 / 0.04);
    transform: translateY(-1px);
  }

  @media (prefers-reduced-motion: reduce) {
    .kr-oem-row--left .kr-oem-track,
    .kr-oem-row--right .kr-oem-track { animation: none; }
  }
</style>
