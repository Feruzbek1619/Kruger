---
import { t } from '@/lib/i18n'
import Icon from '@/components/ui/Icon.astro'
import categories from '@/mocks/categories.json'
import type { ProductCategory } from '@/types'
const lang = (Astro.currentLocale ?? 'ru') as 'ru' | 'en' | 'de'
const items = categories as ProductCategory[]
---
<section class="bg-bg-soft py-16 md:py-24">
  <div class="container-page">
    <div class="text-center max-w-2xl mx-auto mb-10 md:mb-14">
      <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight">{t(lang, 'range.title')}</h2>
      <p class="mt-3 text-text-muted">{t(lang, 'range.subtitle')}</p>
    </div>
    <ul class="grid gap-3 md:gap-4 grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
      {items.map((c) => (
        <li>
          <a href={c.href} class="group flex items-start gap-4 h-full p-5 bg-bg rounded-lg border border-border-soft hover:border-primary hover:shadow-md transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2">
            <span class="inline-flex h-11 w-11 items-center justify-center rounded-md bg-bg-soft text-primary shrink-0 group-hover:bg-primary group-hover:text-text-inverse transition-colors">
              <Icon name={c.icon} class="h-5 w-5" />
            </span>
            <span class="min-w-0">
              <span class="block font-display font-bold text-sm md:text-base text-text leading-snug">{c.title}</span>
              <span class="block text-xs text-text-muted mt-1 line-clamp-2">{c.slogan}</span>
            </span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>
