---
import { t } from '@/lib/i18n'
import Icon from '@/components/ui/Icon.astro'
const lang = (Astro.currentLocale ?? 'ru') as 'ru' | 'en' | 'de'

// Geo points (equirectangular projection on 1000x500 canvas)
const dots = [
  { x: 500, y: 145, name: 'Stuttgart',   highlight: true },
  { x: 525, y: 160, name: 'Vienna' },
  { x: 545, y: 150, name: 'Warsaw' },
  { x: 580, y: 145, name: 'Moscow' },
  { x: 530, y: 175, name: 'Rome' },
  { x: 480, y: 175, name: 'Madrid' },
  { x: 555, y: 195, name: 'Istanbul' },
  { x: 605, y: 200, name: 'Tehran' },
  { x: 670, y: 200, name: 'Tashkent',    highlight: true },
  { x: 700, y: 215, name: 'Almaty' },
  { x: 720, y: 235, name: 'Delhi' },
  { x: 880, y: 195, name: 'Tokyo' },
  { x: 855, y: 215, name: 'Shanghai' },
  { x: 545, y: 285, name: 'Lagos' },
  { x: 595, y: 305, name: 'Nairobi' },
  { x: 575, y: 365, name: 'Cape Town' },
  { x: 215, y: 165, name: 'Vancouver' },
  { x: 270, y: 195, name: 'New York' },
  { x: 235, y: 220, name: 'Mexico City' },
  { x: 305, y: 350, name: 'São Paulo' },
  { x: 290, y: 400, name: 'Buenos Aires' },
  { x: 870, y: 365, name: 'Sydney' },
]
---
<section class="relative bg-bg-soft pt-16 md:pt-24 pb-16 md:pb-24 overflow-hidden">
  <!-- Hero header (red bar with copy) -->
  <div class="relative bg-primary text-text-inverse overflow-hidden">
    <span class="absolute top-0 left-0 right-0 h-1 bg-[#F8CC0F]" aria-hidden="true" />
    <div
      class="absolute -right-24 -top-16 w-72 h-72 rotate-[18deg] bg-[#F8CC0F]/10 pointer-events-none"
      aria-hidden="true"
    />
    <div class="relative container-page py-12 md:py-16 text-center">
      <div class="inline-flex items-center gap-3 mb-3">
        <span class="inline-block h-0.5 w-8 bg-[#F8CC0F]" aria-hidden="true" />
        <p class="text-[10px] md:text-xs font-bold tracking-[0.22em] text-[#F8CC0F] uppercase">Global Reach</p>
        <span class="inline-block h-0.5 w-8 bg-[#F8CC0F]" aria-hidden="true" />
      </div>
      <h2 class="font-display text-3xl md:text-5xl font-extrabold tracking-tight leading-[1.05]">
        {t(lang, 'map.title')}
      </h2>
      <p class="mt-4 max-w-2xl mx-auto text-sm md:text-base opacity-90 leading-relaxed">
        {t(lang, 'map.subtitle')}
      </p>
    </div>
  </div>

  <!-- Map card with stats badges -->
  <div class="container-page py-10 md:py-16">
    <div class="relative bg-bg rounded-2xl p-4 md:p-8 shadow-lg overflow-hidden">
      <!-- Yellow corner accent -->
      <span
        class="absolute top-0 right-0 w-24 h-24 bg-[#F8CC0F]/15 pointer-events-none"
        style="clip-path: polygon(100% 0, 0 0, 100% 100%);"
        aria-hidden="true"
      />

      <svg viewBox="0 0 1000 500" class="w-full h-auto" role="img" aria-label="Карта мира с точками присутствия Krüger">
        <rect width="1000" height="500" fill="var(--color-illus-bg)" rx="12" />

        <!-- Continents (упрощённые, но узнаваемые силуэты) -->
        <g fill="var(--color-illus-land)">
          <!-- North America -->
          <path d="M85 100 Q105 85 145 88 L195 95 Q230 100 265 115 L290 130 Q300 150 295 175 L285 200 Q265 225 235 235 L205 240 Q175 245 150 240 L125 235 Q100 230 85 215 L75 195 Q70 165 75 130 Q78 110 85 100 Z M50 85 L75 80 L80 95 L60 100 Z" />
          <!-- Greenland -->
          <path d="M340 85 Q360 80 380 90 L385 110 Q380 130 365 135 L345 130 Q335 110 340 85 Z" />
          <!-- South America -->
          <path d="M255 260 Q275 250 295 265 L315 280 Q325 305 320 335 L310 365 Q300 395 285 415 L270 435 Q260 445 250 440 L240 420 Q235 395 240 370 L245 340 Q248 305 250 280 Q252 265 255 260 Z" />
          <!-- Europe -->
          <path d="M450 110 Q465 100 485 105 L510 110 Q535 115 555 125 L575 140 Q585 155 580 170 L570 185 Q555 195 535 195 L510 198 Q485 200 465 195 L445 185 Q430 170 432 150 Q435 125 450 110 Z M455 90 L475 85 L475 100 L460 102 Z" />
          <!-- Africa -->
          <path d="M475 215 L515 210 Q545 215 570 230 L590 250 Q600 275 595 305 L585 340 Q575 370 560 395 L540 410 Q520 415 510 405 L495 385 Q485 360 480 335 L475 305 Q472 275 472 250 Q472 230 475 215 Z" />
          <!-- Madagascar -->
          <path d="M615 360 Q625 355 628 370 L625 390 Q620 400 615 395 Q612 380 615 360 Z" />
          <!-- Asia (большой массив) -->
          <path d="M580 95 Q620 85 670 88 L730 95 Q790 105 840 120 L880 135 Q905 150 910 175 L905 200 Q890 225 855 235 L815 240 Q780 240 745 230 L705 220 Q670 210 640 215 L605 215 Q580 210 575 195 Q570 175 570 150 Q572 120 580 95 Z" />
          <!-- India peninsula -->
          <path d="M695 220 Q720 225 730 245 L725 270 Q715 285 700 280 Q685 270 690 245 Q692 225 695 220 Z" />
          <!-- Southeast Asia / Indonesia -->
          <path d="M800 270 Q820 265 845 275 L865 285 Q870 295 860 300 L840 298 Q815 295 800 285 Q795 275 800 270 Z" />
          <!-- Japan -->
          <path d="M885 175 Q895 175 895 195 L890 215 Q882 220 880 205 Q878 185 885 175 Z" />
          <!-- UK / Ireland -->
          <path d="M448 130 Q455 128 458 140 L455 155 Q448 158 446 148 Q444 135 448 130 Z" />
          <!-- Australia -->
          <path d="M820 350 Q855 345 885 355 L900 370 Q905 385 895 395 L870 400 Q840 400 820 390 L808 378 Q805 360 820 350 Z" />
          <!-- New Zealand -->
          <path d="M925 405 L935 410 L933 425 L925 425 Z" />
        </g>

        <!-- Highlight Kazakhstan / EU region (как в Figma) -->
        <ellipse cx="660" cy="170" rx="40" ry="22" fill="var(--primary)" opacity="0.15" />

        <!-- Dots -->
        {dots.map((d, i) => (
          <g>
            <circle cx={d.x} cy={d.y} r={d.highlight ? 16 : 12} fill="var(--primary)" opacity="0.18">
              <animate attributeName="r" values={d.highlight ? '12;20;12' : '8;14;8'} dur="3s" repeatCount="indefinite" begin={`${(i * 0.18) % 2.5}s`} />
              <animate attributeName="opacity" values="0.3;0.08;0.3" dur="3s" repeatCount="indefinite" begin={`${(i * 0.18) % 2.5}s`} />
            </circle>
            <circle cx={d.x} cy={d.y} r={d.highlight ? 5.5 : 4} fill="var(--primary)" stroke="white" stroke-width="1.5">
              <title>{d.name}</title>
            </circle>
          </g>
        ))}
      </svg>

      <!-- Mini-stats below map -->
      <div class="mt-6 grid grid-cols-3 gap-4 pt-6 border-t border-border-soft">
        <div class="text-center">
          <p class="font-display text-xl md:text-2xl font-extrabold text-primary">50+</p>
          <p class="text-[10px] md:text-xs uppercase tracking-wider text-text-muted mt-1">стран</p>
        </div>
        <div class="text-center border-x border-border-soft">
          <p class="font-display text-xl md:text-2xl font-extrabold text-primary">5</p>
          <p class="text-[10px] md:text-xs uppercase tracking-wider text-text-muted mt-1">континентов</p>
        </div>
        <div class="text-center">
          <p class="font-display text-xl md:text-2xl font-extrabold text-primary">1.5k+</p>
          <p class="text-[10px] md:text-xs uppercase tracking-wider text-text-muted mt-1">партнёров</p>
        </div>
      </div>
    </div>

    <div class="mt-8 md:mt-10 text-center">
      <p class="text-text-muted mb-4 text-sm md:text-base">{t(lang, 'map.ctaText')}</p>
      <a
        href="/contact/"
        class="group inline-flex items-center gap-3 h-12 pl-6 pr-2 rounded-pill bg-primary text-text-inverse font-semibold hover:bg-primary-hover transition-colors"
      >
        <span>{t(lang, 'map.ctaBtn')}</span>
        <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-[#F8CC0F] text-text transition-transform group-hover:translate-x-1">
          <Icon name="arrowRight" class="h-4 w-4" />
        </span>
      </a>
    </div>
  </div>
</section>
