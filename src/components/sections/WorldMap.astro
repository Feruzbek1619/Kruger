---
/**
 * WorldMap — Global Reach section (tomoil.de-style).
 *
 * Структура:
 *   ┌─────────────────────────────────────────────────┐
 *   │  Title (left)        ●─────● CTA (right)        │
 *   │                                                  │
 *   │           [ DETAILED WORLD MAP ]                │
 *   │  • 256 стран из @svg-maps/world                 │
 *   │  • Highlight country (Kazakhstan) — red fill    │
 *   │  • Маркеры: жёлтое кольцо + красная точка       │
 *   │  • Hover: tooltip с флагом + name              │
 *   │                                                  │
 *   └─────────────────────────────────────────────────┘
 *
 * Источник стран: src/mocks/presence-countries.json (когда подключим
 * Django admin — заменим на API endpoint /api/countries/, формат тот же).
 */
import { t } from '@/lib/i18n'
import worldMap from '@svg-maps/world'
import presence from '@/mocks/presence-countries.json'
import { ArrowRight } from 'lucide-vue-next'
import 'flag-icons/css/flag-icons.min.css'

const lang = (Astro.currentLocale ?? 'ru') as 'ru' | 'en' | 'de'

const map = (worldMap as any).default ?? worldMap
const viewBox: string = map.viewBox
const locations: { name: string; id: string; path: string }[] = map.locations

const HIGHLIGHT_ID = presence.highlightId
const markers = presence.markers
---
<section class="bg-bg-soft py-16 md:py-24">
  <div class="container-page">
    <article class="relative bg-bg rounded-2xl overflow-hidden">

      <!-- ━━━━━━━━ Title + CTA top row (tomoil-style) ━━━━━━━━ -->
      <header class="px-6 md:px-12 pt-8 md:pt-10 pb-2 flex flex-col md:flex-row md:items-center md:justify-between gap-5 md:gap-8">
        <div class="flex-1">
          <h2 class="font-display text-2xl md:text-3xl lg:text-4xl font-extrabold tracking-tight leading-[1.1] text-text">
            {t(lang, 'map.title')}
          </h2>
          <p class="mt-2 text-sm md:text-base text-text-muted max-w-2xl leading-relaxed">
            {t(lang, 'map.subtitle')}
          </p>
        </div>
        <a
          href="/contact/"
          class="kr-mapcta group inline-flex items-center gap-3 h-12 pl-6 pr-2 rounded-pill bg-primary text-text-inverse font-semibold hover:bg-primary-hover transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2 self-start md:self-auto shrink-0"
        >
          <span>{t(lang, 'map.ctaBtn')}</span>
          <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-brand-yellow text-text transition-transform group-hover:translate-x-1">
            <ArrowRight :size="16" :stroke-width="2.5" aria-hidden="true" />
          </span>
        </a>
      </header>

      <!-- ━━━━━━━━ Detailed world map ━━━━━━━━ -->
      <div class="kr-worldmap relative px-3 md:px-8 pt-4 pb-6 md:pb-10">
        <svg
          viewBox={viewBox}
          class="w-full h-auto block"
          role="img"
          aria-label="Карта мира с точками присутствия Krüger"
          xmlns="http://www.w3.org/2000/svg"
        >
          <!-- Все страны -->
          <g class="kr-countries">
            {locations.map((loc) => {
              const isHL = loc.id === HIGHLIGHT_ID
              return (
                <path
                  d={loc.path}
                  data-country-id={loc.id}
                  data-country-name={loc.name}
                  style={{
                    fill: isHL ? 'var(--color-primary)' : 'var(--color-illus-land)',
                    stroke: 'rgba(255,255,255,0.9)',
                    strokeWidth: 0.4,
                  }}
                />
              )
            })}
          </g>

          <!-- Маркеры: жёлтое кольцо + красная точка (концентрические) -->
          <g class="kr-markers">
            {markers.map((m) => {
              const ring = m.highlight ? 11 : 8
              const dot  = m.highlight ? 5 : 3.5
              return (
                <g
                  class="kr-marker"
                  data-country-id={m.id}
                  data-country-name={m.name}
                  data-city={m.city}
                  style="cursor: pointer;"
                >
                  <!-- yellow outer ring -->
                  <circle cx={m.x} cy={m.y} r={ring} style="fill: var(--color-brand-yellow); stroke: white; stroke-width: 1;" />
                  <!-- red inner dot -->
                  <circle cx={m.x} cy={m.y} r={dot} style="fill: var(--color-primary);" />
                </g>
              )
            })}
          </g>
        </svg>

        <!-- Tooltip (single instance, JS-controlled) -->
        <div
          id="kr-map-tooltip"
          role="tooltip"
          class="absolute pointer-events-none opacity-0 transition-opacity duration-150 bg-bg shadow-xl rounded-lg border border-border-soft px-3 py-2 flex items-center gap-2.5 z-10"
          style="transform: translate(-50%, calc(-100% - 14px));"
        >
          <span id="kr-map-flag" class="fi kr-flag w-6 h-4 rounded-sm shadow-sm" aria-hidden="true"></span>
          <span id="kr-map-name" class="font-display font-semibold text-sm text-text whitespace-nowrap"></span>
        </div>
      </div>
    </article>
  </div>
</section>

<script>
  // Минимальный vanilla-JS hover-tooltip для маркеров.
  // Не Vue island — экономит KB в bundle, тултип единственный для всей карты.
  (function initWorldMapTooltip() {
    const root = document.querySelector<HTMLElement>('.kr-worldmap')
    if (!root) return
    const tooltip = root.querySelector<HTMLElement>('#kr-map-tooltip')
    const flagEl = root.querySelector<HTMLElement>('#kr-map-flag')
    const nameEl = root.querySelector<HTMLElement>('#kr-map-name')
    if (!tooltip || !flagEl || !nameEl) return

    const markerEls = root.querySelectorAll<SVGGElement>('.kr-marker')

    function show(target: SVGGElement, ev: MouseEvent) {
      const id = target.getAttribute('data-country-id') ?? ''
      const name = target.getAttribute('data-country-name') ?? ''
      // обновить флаг через CSS-класс flag-icons
      flagEl!.className = `fi fi-${id.toLowerCase()} kr-flag w-6 h-4 rounded-sm shadow-sm`
      nameEl!.textContent = name
      // позиционирование относительно root
      const rootRect = root!.getBoundingClientRect()
      tooltip!.style.left = `${ev.clientX - rootRect.left}px`
      tooltip!.style.top = `${ev.clientY - rootRect.top}px`
      tooltip!.style.opacity = '1'
    }

    function hide() {
      tooltip!.style.opacity = '0'
    }

    markerEls.forEach((el) => {
      el.addEventListener('mouseenter', (ev) => show(el, ev as MouseEvent))
      el.addEventListener('mousemove', (ev) => {
        const rootRect = root!.getBoundingClientRect()
        tooltip!.style.left = `${(ev as MouseEvent).clientX - rootRect.left}px`
        tooltip!.style.top = `${(ev as MouseEvent).clientY - rootRect.top}px`
      })
      el.addEventListener('mouseleave', hide)
      // touch: tap → show, tap outside → hide handled below
      el.addEventListener('touchstart', (ev) => {
        const t = (ev as TouchEvent).touches[0]
        show(el, { clientX: t.clientX, clientY: t.clientY } as MouseEvent)
      }, { passive: true })
    })

    // Hide on outside click (mobile)
    document.addEventListener('click', (ev) => {
      const t = ev.target as Element | null
      if (t && !t.closest('.kr-marker')) hide()
    })
  })()
</script>

<style>
  /* Hover на маркер — увеличить кольцо */
  .kr-marker:hover circle:first-child {
    r: 14;
    transition: r 200ms ease-out;
  }
  .kr-marker circle {
    transition: r 200ms ease-out;
  }
  /* Hover на страну (любую) — лёгкое затемнение для подсветки */
  .kr-countries path {
    transition: fill 150ms ease-out;
  }
  .kr-countries path:hover {
    fill: var(--color-illus-mid) !important;
  }
  /* Highlighted country (Kazakhstan) — насыщенный hover */
  .kr-countries path[data-country-id="kz"]:hover {
    fill: var(--color-primary-hover) !important;
  }

  /* flag-icons override: фиксированные размеры */
  .kr-flag {
    background-size: cover;
    background-position: center;
  }

  @media (prefers-reduced-motion: reduce) {
    .kr-marker circle,
    .kr-countries path,
    #kr-map-tooltip {
      transition: none !important;
    }
  }
</style>
