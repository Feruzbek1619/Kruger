---
import { t } from '@/lib/i18n'
import Icon from '@/components/ui/Icon.astro'
const lang = (Astro.currentLocale ?? 'ru') as 'ru' | 'en' | 'de'
---
<section class="relative bg-primary text-text-inverse overflow-hidden">
  <!-- Yellow brand stripe -->
  <span class="absolute top-0 left-0 right-0 h-1 bg-[#F8CC0F]" aria-hidden="true" />
  <!-- Diagonal accent -->
  <div
    class="absolute -right-32 -top-16 w-72 h-72 rotate-[18deg] bg-[#F8CC0F]/10 pointer-events-none"
    aria-hidden="true"
  />

  <div class="relative container-page py-12 md:py-16 grid gap-8 md:gap-10 md:grid-cols-[1fr_auto_auto] items-center">
    <div>
      <h2 class="font-display text-2xl md:text-3xl lg:text-4xl font-extrabold tracking-tight">
        {t(lang, 'footer.contactStripTitle')}
      </h2>
      <p class="mt-2 text-sm md:text-base opacity-85">{t(lang, 'footer.contactStripSubtitle')}</p>
    </div>

    <a
      href={`tel:${t(lang, 'topbar.phone').replace(/\s/g, '')}`}
      class="group flex items-center gap-4 rounded-xl bg-text-inverse/[0.08] hover:bg-text-inverse/[0.15] backdrop-blur-sm border border-text-inverse/15 px-5 py-3.5 transition-colors"
    >
      <span class="inline-flex h-11 w-11 items-center justify-center rounded-full bg-[#F8CC0F] text-text shrink-0 transition-transform group-hover:scale-110">
        <Icon name="phone" class="h-5 w-5" />
      </span>
      <span>
        <span class="block text-[10px] uppercase tracking-[0.18em] opacity-70 font-semibold">
          {t(lang, 'footer.phoneLabel')}
        </span>
        <span class="block font-display font-bold text-base lg:text-lg">{t(lang, 'topbar.phone')}</span>
      </span>
    </a>

    <a
      href={`mailto:${t(lang, 'topbar.email')}`}
      class="group flex items-center gap-4 rounded-xl bg-text-inverse/[0.08] hover:bg-text-inverse/[0.15] backdrop-blur-sm border border-text-inverse/15 px-5 py-3.5 transition-colors"
    >
      <span class="inline-flex h-11 w-11 items-center justify-center rounded-full bg-[#F8CC0F] text-text shrink-0 transition-transform group-hover:scale-110">
        <Icon name="mail" class="h-5 w-5" />
      </span>
      <span>
        <span class="block text-[10px] uppercase tracking-[0.18em] opacity-70 font-semibold">
          {t(lang, 'footer.emailLabel')}
        </span>
        <span class="block font-display font-bold text-base lg:text-lg">{t(lang, 'topbar.email')}</span>
      </span>
    </a>
  </div>
</section>
