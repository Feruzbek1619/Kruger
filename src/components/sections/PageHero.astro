---
interface Props {
  eyebrow?: string
  title: string
  lead?: string
  breadcrumbs?: { label: string; href?: string }[]
  variant?: 'light' | 'dark'
}
const {
  eyebrow,
  title,
  lead,
  breadcrumbs = [],
  variant = 'light',
} = Astro.props

const dark = variant === 'dark'
---
<section class:list={[dark ? 'bg-bg-dark text-text-inverse' : 'bg-bg-soft text-text']}>
  <div class="container-page py-14 md:py-20">
    {breadcrumbs.length > 0 && (
      <nav aria-label="Хлебные крошки" class:list={['mb-6 text-xs', dark ? 'text-text-inverse/70' : 'text-text-muted']}>
        <ol class="flex flex-wrap items-center gap-2">
          {breadcrumbs.map((b, i) => (
            <li class="inline-flex items-center gap-2">
              {b.href ? <a href={b.href} class="hover:text-primary">{b.label}</a> : <span>{b.label}</span>}
              {i < breadcrumbs.length - 1 && <span aria-hidden="true">/</span>}
            </li>
          ))}
        </ol>
      </nav>
    )}
    {eyebrow && <p class="text-xs font-semibold tracking-[0.18em] text-primary uppercase mb-3">{eyebrow}</p>}
    <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-extrabold tracking-tight max-w-4xl">{title}</h1>
    {lead && <p class:list={['mt-5 text-lg md:text-xl max-w-3xl', dark ? 'text-text-inverse/85' : 'text-text-muted']}>{lead}</p>}
  </div>
</section>
