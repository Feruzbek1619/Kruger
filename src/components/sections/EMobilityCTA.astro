---
import { t } from '@/lib/i18n'
const lang = (Astro.currentLocale ?? 'ru') as 'ru' | 'en' | 'de'
---
<section class="relative bg-bg-dark text-text-inverse overflow-hidden">
  <div class="absolute inset-0" aria-hidden="true">
    <svg viewBox="0 0 1200 500" class="w-full h-full" preserveAspectRatio="xMidYMid slice">
      <defs>
        <radialGradient id="ev-g" cx="70%" cy="50%" r="60%">
          <stop offset="0%" stop-color="var(--primary)" stop-opacity="0.4"/>
          <stop offset="100%" stop-color="var(--color-illus-deep)" stop-opacity="0"/>
        </radialGradient>
      </defs>
      <rect width="1200" height="500" fill="var(--color-illus-deep)"/>
      <rect width="1200" height="500" fill="url(#ev-g)"/>
      <g opacity="0.5" fill="var(--color-illus-mid)">
        <circle cx="900" cy="280" r="160"/>
        <circle cx="900" cy="280" r="80" fill="var(--color-illus-deep)"/>
      </g>
      <g stroke="var(--primary)" stroke-width="2" fill="none" opacity=".7">
        <path d="M880 260l20-30 10 20 20-25" stroke-linecap="round" stroke-linejoin="round"/>
      </g>
    </svg>
  </div>
  <div class="relative container-page py-20 md:py-28 max-w-3xl">
    <p class="text-xs md:text-sm font-semibold tracking-[0.18em] text-primary uppercase">{t(lang, 'ev.eyebrow')}</p>
    <h2 class="mt-4 font-display text-3xl md:text-5xl font-extrabold tracking-tight">{t(lang, 'ev.title')}</h2>
    <p class="mt-5 text-text-inverse/85 max-w-xl leading-relaxed">{t(lang, 'ev.text')}</p>
    <a href="/products/category/ev-fluids/" class="mt-8 inline-flex h-12 px-7 items-center rounded-pill bg-primary text-text-inverse font-medium hover:bg-primary-hover transition-colors">
      {t(lang, 'ev.cta')}
    </a>
  </div>
</section>
