---
import { t } from '@/lib/i18n'
import partners from '@/mocks/partners.json'
import type { Partner } from '@/types'
const lang = (Astro.currentLocale ?? 'ru') as 'ru' | 'en' | 'de'
const items = partners as Partner[]
---
<section class="bg-bg py-16 md:py-24">
  <div class="container-page">
    <div class="text-center max-w-2xl mx-auto mb-10 md:mb-14">
      <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight">{t(lang, 'partners.title')}</h2>
      <p class="mt-2 text-text-muted">{t(lang, 'partners.subtitle')}</p>
    </div>
    <ul class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-3 md:gap-4">
      {items.map((p) => (
        <li>
          <div
            class="h-20 md:h-24 flex items-center justify-center rounded-lg bg-bg-soft px-3 grayscale opacity-60 hover:grayscale-0 hover:opacity-100 hover:bg-bg transition-all duration-200"
            title={p.name}
          >
            {p.logo ? (
              <img src={p.logo} alt={p.name} loading="lazy" class="max-h-full max-w-full object-contain" />
            ) : (
              <span class="font-display text-xs md:text-sm text-text-subtle text-center font-medium leading-tight">{p.name}</span>
            )}
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
