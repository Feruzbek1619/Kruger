---
import { t } from '@/lib/i18n'
import partners from '@/mocks/partners.json'
import type { Partner } from '@/types'
const lang = (Astro.currentLocale ?? 'ru') as 'ru' | 'en' | 'de'
const items = partners as Partner[]
---
<section class="bg-bg py-16 md:py-24">
  <div class="container-page">
    <div class="text-center mb-10 md:mb-14">
      <div class="inline-flex items-center gap-3 mb-3">
        <span class="inline-block h-0.5 w-8 bg-primary" aria-hidden="true" />
        <p class="text-[10px] md:text-xs font-bold tracking-[0.22em] text-primary uppercase">Trusted By</p>
        <span class="inline-block h-0.5 w-8 bg-primary" aria-hidden="true" />
      </div>
      <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-extrabold tracking-tight leading-[1.1]">
        {t(lang, 'partners.title')}
      </h2>
      <p class="mt-3 max-w-2xl mx-auto text-sm md:text-base text-text-muted">{t(lang, 'partners.subtitle')}</p>
    </div>

    <ul class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-2.5 md:gap-3">
      {items.map((p) => (
        <li>
          <div
            class="group h-20 md:h-24 flex items-center justify-center rounded-xl bg-bg-soft px-3 border border-transparent hover:border-primary/30 hover:bg-bg hover:shadow-md transition-all duration-200"
            title={p.name}
          >
            {p.logo ? (
              <img
                src={p.logo}
                alt={p.name}
                loading="lazy"
                class="max-h-full max-w-full object-contain grayscale opacity-50 group-hover:grayscale-0 group-hover:opacity-100 transition-all"
              />
            ) : (
              <span class="font-display text-xs md:text-sm text-text-subtle text-center font-bold leading-tight uppercase tracking-wider group-hover:text-text transition-colors">
                {p.name}
              </span>
            )}
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
