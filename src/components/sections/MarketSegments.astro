---
import { t } from '@/lib/i18n'
import Icon from '@/components/ui/Icon.astro'
import SegmentIcon from '@/components/ui/SegmentIcon.astro'
import segments from '@/mocks/segments.json'
import type { MarketSegment } from '@/types'

const lang = (Astro.currentLocale ?? 'ru') as 'ru' | 'en' | 'de'
const items = segments as MarketSegment[]
---
<section class="bg-bg-soft py-16 md:py-24">
  <div class="container-page">
    <div class="flex items-end justify-between gap-6 mb-10 md:mb-14 flex-wrap">
      <div class="max-w-2xl">
        <div class="flex items-center gap-3 mb-3">
          <span class="inline-block h-0.5 w-8 bg-primary" aria-hidden="true" />
          <p class="text-[10px] md:text-xs font-bold tracking-[0.22em] text-primary uppercase">ДЛЯ ЛЮБОЙ ТЕХНИКИ</p>
        </div>
        <h2 class="font-display text-3xl md:text-4xl lg:text-5xl font-extrabold tracking-tight leading-[1.1]">
          {t(lang, 'segments.title')}
        </h2>
        <p class="mt-3 text-sm md:text-base text-text-muted">{t(lang, 'segments.subtitle')}</p>
      </div>
      <a
        href="/products/"
        class="hidden md:inline-flex h-11 px-5 items-center rounded-pill bg-bg text-text font-medium hover:bg-bg-muted transition-colors text-sm border border-border-soft"
      >
        {t(lang, 'segments.more')}
      </a>
    </div>

    <ul class="grid gap-3 md:gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
      {items.map((s, i) => (
        <li>
          <a
            href={s.href}
            class="kr-segment-card group relative flex flex-col h-full p-6 md:p-7 bg-bg rounded-xl border border-border-soft overflow-hidden hover:bg-bg-dark hover:text-text-inverse hover:border-bg-dark hover:shadow-xl transition-all duration-300 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
          >
            <!-- Yellow corner accent (бренд) -->
            <span
              class="absolute top-0 right-0 w-16 h-16 bg-brand-yellow opacity-0 group-hover:opacity-100 transition-opacity duration-300"
              style="clip-path: polygon(100% 0, 0 0, 100% 100%);"
              aria-hidden="true"
            />
            <span
              class="inline-flex h-16 w-16 items-center justify-center rounded-xl bg-primary text-text-inverse mb-6 transition-all duration-300 group-hover:bg-brand-yellow group-hover:text-text group-hover:scale-110 group-hover:rotate-[-4deg]"
              aria-hidden="true"
            >
              <SegmentIcon segment={s.id as any} class="h-8 w-8" />
            </span>

            <h3 class="font-display font-bold text-lg md:text-xl leading-snug">{s.title}</h3>
            <p class="mt-2 text-sm text-text-muted group-hover:text-text-inverse/70 transition-colors flex-1">
              {s.subtitle}
            </p>

            <div class="mt-5 inline-flex items-center gap-2 text-sm font-semibold text-primary group-hover:text-brand-yellow transition-colors">
              <span>Подробнее</span>
              <Icon name="arrowRight" class="h-4 w-4 transition-transform group-hover:translate-x-1" />
            </div>
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile CTA -->
    <div class="md:hidden mt-6 text-center">
      <a
        href="/products/"
        class="group inline-flex items-center gap-3 h-12 pl-6 pr-2 rounded-pill bg-bg hover:bg-bg-muted text-text font-semibold border border-border-soft transition-colors text-sm"
      >
        <span>{t(lang, 'segments.more')}</span>
        <span class="inline-flex h-9 w-9 items-center justify-center rounded-full bg-primary text-text-inverse transition-transform group-hover:translate-x-1">
          <Icon name="arrowRight" size={16} strokeWidth={2.5} />
        </span>
      </a>
    </div>
  </div>
</section>
