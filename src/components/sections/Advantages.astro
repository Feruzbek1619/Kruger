---
import { t } from '@/lib/i18n'
import Icon from '@/components/ui/Icon.astro'
import ru from '@/i18n/ru.json'
const lang = (Astro.currentLocale ?? 'ru') as 'ru' | 'en' | 'de'

const icons = ['factory','shield','spark','drop','cog','globe'] as const
const items = ru.advantages.items
---
<section class="bg-bg py-16 md:py-24">
  <div class="container-page">
    <div class="max-w-2xl mb-12 md:mb-16">
      <p class="text-xs font-semibold tracking-[0.18em] text-primary uppercase mb-3">
        {t(lang, 'advantages.eyebrow')}
      </p>
      <h2 class="font-display text-3xl md:text-4xl font-bold tracking-tight">
        {t(lang, 'advantages.title')}
      </h2>
      <p class="mt-3 text-text-muted leading-relaxed">
        {t(lang, 'advantages.subtitle')}
      </p>
    </div>

    <ul class="grid gap-6 md:gap-8 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
      {items.map((item, i) => (
        <li class="kr-reveal flex gap-5">
          <span
            class="inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary"
            aria-hidden="true"
          >
            <Icon name={icons[i] ?? 'spark'} class="h-6 w-6" />
          </span>
          <div>
            <h3 class="font-display font-bold text-base md:text-lg leading-snug text-text mb-1.5">
              {item.title}
            </h3>
            <p class="text-sm text-text-muted leading-relaxed">{item.text}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>
