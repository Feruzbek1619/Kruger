---
import { t } from '@/lib/i18n'
import Icon from '@/components/ui/Icon.astro'
import ru from '@/i18n/ru.json'
const lang = (Astro.currentLocale ?? 'ru') as 'ru' | 'en' | 'de'

const icons = ['factory','shield','spark','drop','cog','globe'] as const
const items = ru.advantages.items
---
<section class="relative bg-bg py-16 md:py-24 overflow-hidden">
  <!-- Subtle K-watermark в фоне -->
  <span
    class="absolute -right-20 top-1/2 -translate-y-1/2 font-display text-[28rem] font-extrabold text-text/[0.025] leading-none select-none pointer-events-none hidden lg:block"
    aria-hidden="true"
  >K</span>

  <div class="relative container-page">
    <div class="max-w-2xl mb-12 md:mb-16">
      <div class="flex items-center gap-3 mb-4">
        <span class="inline-block h-0.5 w-10 bg-primary" aria-hidden="true" />
        <p class="text-xs font-bold tracking-[0.2em] text-primary uppercase">
          {t(lang, 'advantages.eyebrow')}
        </p>
      </div>
      <h2 class="font-display text-3xl md:text-5xl font-extrabold tracking-tight leading-[1.1]">
        {t(lang, 'advantages.title')}
      </h2>
      <p class="mt-4 text-base md:text-lg text-text-muted leading-relaxed">
        {t(lang, 'advantages.subtitle')}
      </p>
    </div>

    <ul class="grid gap-4 md:gap-5 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
      {items.map((item, i) => (
        <li class="kr-reveal group relative bg-bg-soft hover:bg-bg rounded-xl p-6 md:p-7 border border-border-soft hover:border-primary/30 hover:shadow-lg transition-all duration-300 overflow-hidden">
          <!-- Yellow corner accent (бренд) -->
          <span class="absolute top-0 right-0 w-12 h-12 bg-brand-yellow opacity-0 group-hover:opacity-100 transition-opacity" style="clip-path: polygon(100% 0, 0 0, 100% 100%);" aria-hidden="true" />

          <!-- Number badge -->
          <span class="absolute top-6 right-6 font-mono text-xs tracking-wider text-text-subtle">
            {String(i + 1).padStart(2, '0')}
          </span>

          <span
            class="inline-flex h-14 w-14 items-center justify-center rounded-xl bg-primary text-text-inverse mb-5 transition-all duration-300 group-hover:scale-110 group-hover:rotate-[-4deg]"
            aria-hidden="true"
          >
            <Icon name={icons[i] ?? 'spark'} class="h-7 w-7" />
          </span>

          <h3 class="font-display font-bold text-lg md:text-xl leading-snug text-text mb-3">
            {item.title}
          </h3>
          <p class="text-sm text-text-muted leading-relaxed">{item.text}</p>
        </li>
      ))}
    </ul>
  </div>
</section>
