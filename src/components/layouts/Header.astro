---
import { t } from '@/lib/i18n'
import Logo from '@/components/ui/Logo.astro'
import Icon from '@/components/ui/Icon.astro'
import MobileMenu from '@/components/layouts/MobileMenu.vue'

const lang = (Astro.currentLocale ?? 'ru') as 'ru' | 'en' | 'de'
const path = Astro.url.pathname

const items = [
  { label: t(lang, 'nav.home'),    href: '/' },
  { label: t(lang, 'nav.service'), href: '/services/' },
  {
    label: t(lang, 'nav.about'),
    href: '/about/',
    children: [
      { label: t(lang, 'nav.aboutGlance'),      href: '/about/glance/' },
      { label: t(lang, 'nav.aboutVision'),      href: '/about/vision-mission/' },
      { label: t(lang, 'nav.aboutCommitments'), href: '/about/commitments/' },
    ],
  },
  { label: t(lang, 'nav.services'), href: '/services/' },
  { label: t(lang, 'nav.news'),     href: '/news/' },
  { label: t(lang, 'nav.faq'),      href: '/faq/' },
  { label: t(lang, 'nav.contact'),  href: '/contact/' },
]
---
<header class="sticky top-0 z-sticky bg-bg border-b border-border-soft">
  <div class="container-page flex items-center justify-between gap-6 h-16 md:h-20">
    <a href="/" class="shrink-0 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary rounded">
      <Logo class="h-9 md:h-11" />
    </a>

    <nav class="hidden md:flex items-center gap-1 lg:gap-2" aria-label="Главное меню">
      {items.map((it) => (
        it.children ? (
          <div class="relative group">
            <a
              href={it.href}
              class:list={[
                'inline-flex items-center gap-1 px-3 py-2 rounded text-sm lg:text-base font-medium transition-colors hover:text-primary',
                path.startsWith(it.href) ? 'text-text font-bold' : 'text-text',
              ]}
            >
              {it.label}
              <svg viewBox="0 0 12 12" class="h-3 w-3" fill="none" stroke="currentColor" stroke-width="2"><path d="m3 5 3 3 3-3" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <div class="absolute top-full left-0 pt-2 hidden group-hover:block group-focus-within:block min-w-[14rem]">
              <ul class="bg-bg rounded-md shadow-lg border border-border-soft py-2">
                {it.children.map((c) => (
                  <li>
                    <a
                      href={c.href}
                      class:list={[
                        'block px-4 py-2 text-sm hover:bg-bg-soft hover:text-primary',
                        path === c.href ? 'text-primary font-semibold bg-bg-soft' : 'text-text',
                      ]}
                    >
                      {c.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ) : (
          <a
            href={it.href}
            class:list={[
              'px-3 py-2 rounded text-sm lg:text-base font-medium transition-colors hover:text-primary',
              path === it.href ? 'text-text font-bold' : 'text-text',
            ]}
          >
            {it.label}
          </a>
        )
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <button
        type="button"
        class="hidden md:inline-flex h-10 w-10 items-center justify-center rounded text-text hover:bg-bg-soft focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary"
        aria-label={t(lang, 'nav.search')}
      >
        <Icon name="search" class="h-5 w-5" />
      </button>
      <MobileMenu client:load items={items} />
    </div>
  </div>
</header>
