# ============================================================
# Krüger Frontend — environment variables
# ============================================================
# Copy this file to .env.local and fill values for development.
# In production these are set on Cloudflare Pages / Netlify dashboard.

# ─── Mock toggle ────────────────────────────────────────────
# При true фронт берёт данные из src/mocks/*.json (без бэкенда).
# При false идёт запрос к PUBLIC_API_URL (Phase 7+).
PUBLIC_USE_MOCKS=true

# ─── Backend API (Phase 7) ──────────────────────────────────
# URL Django REST API. Без trailing slash.
# Local dev:    http://localhost:8000/api
# Staging:      https://staging.kruger-oil.de/api
# Production:   https://kruger-oil.de/api
PUBLIC_API_URL=

# ─── Telegram bot (Phase 8) ─────────────────────────────────
# Используется на бэкенде для пересылки заявок. На фронте не нужен.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ─── hCaptcha (Phase 9) ─────────────────────────────────────
# Site key — публичный, в frontend. Secret — на бэке.
PUBLIC_HCAPTCHA_SITE_KEY=

# ─── Analytics (опционально) ────────────────────────────────
# Plausible / Umami / GA4
# PUBLIC_ANALYTICS_DOMAIN=
# PUBLIC_ANALYTICS_URL=

# ─── Error monitoring (опционально) ─────────────────────────
# PUBLIC_SENTRY_DSN=
